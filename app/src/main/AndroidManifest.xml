<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SlagalicaVPL">

        <!-- Launcher entry point redirects to LoginActivity -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:noHistory="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".activities.LoginActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"/>

        <activity
            android:name=".activities.RegisterActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"/>

        <activity
            android:name=".activities.GameActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>

        <activity
            android:name=".activities.ProfileActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"/>

        <activity
            android:name=".activities.HomeActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>

        <activity
            android:name=".activities.LobbyActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>

        <activity
            android:name=".activities.NotificationsActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"/>

        <activity
            android:name=".activities.ChatActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"/>

        <activity
            android:name=".activities.FriendsActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>

        <activity
            android:name=".activities.ChallengeListActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>

        <activity
            android:name=".activities.ChallengeWaitActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>

        <activity
            android:name=".activities.ChallengeResultActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>

        <activity
            android:name=".activities.RankingActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>

        <activity
            android:name=".activities.RankingRewardActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>

        <activity
            android:name=".activities.MissionsActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>

        <activity
            android:name=".activities.TournamentLobbyActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>

        <activity
            android:name=".activities.TournamentResultActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>

        <activity
            android:name=".activities.RegionActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>

        <service
            android:name=".notification.AppFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT"/>
            </intent-filter>
        </service>

    </application>

</manifest>
