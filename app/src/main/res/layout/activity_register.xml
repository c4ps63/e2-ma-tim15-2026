<?xml version="1.0" encoding="utf-8"?>
<!--
  REGISTER · novi cartoon dizajn
  Sačuvani ID-ovi za RegisterActivity.java:
    btnBack (ImageButton), btnRegister (Button)
  Polja: etEmail, etUsername, spinnerRegion, etPassword, etPasswordConfirm
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_sky_gradient"
    tools:context=".activities.RegisterActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="@dimen/status_bar_safe"
        android:paddingBottom="32dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <!-- Back button -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_retro_back"
            android:background="@drawable/btn_cartoon_blue"
            android:contentDescription="Nazad"
            android:padding="12dp"
            android:layout_marginTop="8dp"/>

        <!-- Title -->
        <TextView
            style="@style/TextDisplay.Light"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="12dp"
            android:textSize="34sp"
            android:text="@string/title_register"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:fontFamily="sans-serif"
            android:textColor="#DDEAFF"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            android:text="Pripremi pasoš za put oko sveta."/>

        <!-- Registration card (paper style) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_paper"
            android:padding="20dp"
            android:layout_marginTop="20dp">

            <!-- E-mail -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="@string/lbl_email"
                android:textColor="@color/ink"
                android:textSize="13sp"/>

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:padding="14dp"
                android:background="@drawable/field_input"
                android:inputType="textEmailAddress"
                android:fontFamily="sans-serif"
                android:textSize="16sp"
                android:textColor="@color/ink"/>

            <!-- Korisničko ime -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:fontFamily="sans-serif-black"
                android:text="@string/lbl_uname"
                android:textColor="@color/ink"
                android:textSize="13sp"/>

            <EditText
                android:id="@+id/etUsername"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:padding="14dp"
                android:background="@drawable/field_input"
                android:fontFamily="sans-serif"
                android:textSize="16sp"
                android:textColor="@color/ink"/>

            <!-- Region -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:fontFamily="sans-serif-black"
                android:text="@string/label_region"
                android:textColor="@color/ink"
                android:textSize="13sp"/>

            <Spinner
                android:id="@+id/spinnerRegion"
                android:layout_width="match_parent"
                android:layout_height="@dimen/retro_input_height"
                android:background="@drawable/field_input"
                android:fontFamily="sans-serif"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:entries="@array/regions"
                android:layout_marginTop="6dp"/>

            <!-- Lozinka -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:fontFamily="sans-serif-black"
                android:text="@string/lbl_password"
                android:textColor="@color/ink"
                android:textSize="13sp"/>

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:padding="14dp"
                android:background="@drawable/field_input"
                android:inputType="textPassword"
                android:fontFamily="sans-serif"
                android:textSize="16sp"
                android:textColor="@color/ink"/>

            <!-- Potvrdi lozinku -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:fontFamily="sans-serif-black"
                android:text="@string/lbl_password_confirm"
                android:textColor="@color/ink"
                android:textSize="13sp"/>

            <EditText
                android:id="@+id/etPasswordConfirm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:padding="14dp"
                android:background="@drawable/field_input"
                android:inputType="textPassword"
                android:fontFamily="sans-serif"
                android:textSize="16sp"
                android:textColor="@color/ink"/>

            <!-- Info note -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="sans-serif"
                android:textSize="11sp"
                android:textColor="@color/sky_dark"
                android:text="@string/info_email_confirm"/>

            <!-- Register button (green) -->
            <Button
                android:id="@+id/btnRegister"
                style="@style/CartoonButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:textSize="@dimen/text_btn_lg"
                android:text="@string/cta_register"
                android:background="@drawable/btn_cartoon_green"/>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
