<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/card_paper"
    android:padding="14dp"
    android:layout_marginBottom="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvChallengeCreator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#102341" />

            <TextView
                android:id="@+id/tvChallengeStake"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#444444"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tvChallengePlayers"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#777777"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnChallengeAction"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            style="@style/CartoonButton"
            android:background="@drawable/btn_cartoon_yellow"
            android:textSize="12sp"
            android:text="PRIHVATI" />
    </LinearLayout>
</LinearLayout>
