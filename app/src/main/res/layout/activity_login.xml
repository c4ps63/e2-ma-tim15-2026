<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/retro_bg"
    android:fillViewport="true"
    tools:context=".activities.LoginActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="40dp"
        android:gravity="center_horizontal">

        <!-- Logo area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="64dp"
            android:paddingBottom="40dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SLAGALICA"
                android:fontFamily="monospace"
                android:textSize="40sp"
                android:textStyle="bold"
                android:textColor="@color/retro_ink"
                android:letterSpacing="0.05"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="6dp"
                android:background="@color/retro_ink"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VPL · MOBILNE APLIKACIJE"
                android:fontFamily="monospace"
                android:textSize="11sp"
                android:textColor="@color/retro_dim"
                android:letterSpacing="0.15"/>
        </LinearLayout>

        <!-- Login form card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_retro_card"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PRIJAVA"
                style="@style/RetroLabel"
                android:layout_marginBottom="14dp"/>

            <EditText
                android:id="@+id/etEmailOrUsername"
                android:layout_width="match_parent"
                android:layout_height="@dimen/retro_input_height"
                style="@style/RetroInput"
                android:hint="@string/hint_email_or_username"
                android:inputType="textEmailAddress"
                android:singleLine="true"
                android:layout_marginBottom="10dp"/>

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="@dimen/retro_input_height"
                style="@style/RetroInput"
                android:hint="@string/hint_password"
                android:inputType="textPassword"
                android:singleLine="true"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/tvForgotPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_forgot_password"
                android:fontFamily="monospace"
                android:textSize="10sp"
                android:textColor="@color/retro_acc"
                android:letterSpacing="0.05"
                android:gravity="end"
                android:layout_marginBottom="20dp"
                android:clickable="true"
                android:focusable="true"/>

            <!-- Primary login button (dark with shadow wrapper) -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="52dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginStart="4dp"
                    android:layout_marginTop="4dp"
                    android:background="@color/retro_acc"/>

                <Button
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="4dp"
                    android:layout_marginBottom="4dp"
                    style="@style/RetroButtonDark"
                    android:text="@string/btn_login"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"/>
            </FrameLayout>
        </LinearLayout>

        <!-- Divider -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/retro_dim"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ILI"
                android:fontFamily="monospace"
                android:textSize="10sp"
                android:textColor="@color/retro_dim"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:letterSpacing="0.1"/>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/retro_dim"/>
        </LinearLayout>

        <!-- Register button (light) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="52dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="4dp"
                android:layout_marginTop="4dp"
                android:background="@color/retro_ink"/>

            <Button
                android:id="@+id/btnGoRegister"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginEnd="4dp"
                android:layout_marginBottom="4dp"
                style="@style/RetroButton"
                android:text="@string/btn_register"
                android:insetTop="0dp"
                android:insetBottom="0dp"/>
        </FrameLayout>

    </LinearLayout>
</ScrollView>
