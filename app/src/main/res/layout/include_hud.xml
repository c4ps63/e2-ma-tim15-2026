<?xml version="1.0" encoding="utf-8"?>
<!--
  Reusable HUD bar — <include layout="@layout/include_hud"/> at top of every game fragment.
  NO background declared here — the parent fragment's gradient shows through,
  so the HUD automatically takes the colour of whichever continent/game is active.
  paddingTop=8dp assumes the host Activity handles status-bar insets.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/hud"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="8dp"
    android:paddingBottom="10dp"
    android:paddingStart="12dp"
    android:paddingEnd="12dp">

    <!-- Igrač 1 — avatar lijevo -->
    <TextView
        android:id="@+id/p1_avatar"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_avatar"
        android:gravity="center"
        android:fontFamily="sans-serif-black"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:text="?"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/p1_score"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-black"
        android:textSize="24sp"
        android:textColor="@color/player_blue"
        android:text="0"
        android:layout_marginStart="8dp"
        app:layout_constraintTop_toTopOf="@id/p1_avatar"
        app:layout_constraintStart_toEndOf="@id/p1_avatar"/>

    <TextView
        android:id="@+id/p1_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif"
        android:textStyle="bold"
        android:textSize="12sp"
        android:textColor="@color/player_blue"
        android:text="Luka"
        android:layout_marginStart="8dp"
        app:layout_constraintTop_toBottomOf="@id/p1_score"
        app:layout_constraintStart_toEndOf="@id/p1_avatar"/>

    <!-- Tajmer — centar -->
    <FrameLayout
        android:id="@+id/timer_wrap"
        android:layout_width="52dp"
        android:layout_height="52dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/timer_ring"/>

        <TextView
            android:id="@+id/timer_value"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:fontFamily="sans-serif-black"
            android:textSize="20sp"
            android:textColor="@color/ink"
            android:text="28"/>
    </FrameLayout>

    <!-- Igrač 2 — avatar desno -->
    <TextView
        android:id="@+id/p2_avatar"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_avatar"
        android:gravity="center"
        android:fontFamily="sans-serif-black"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:text="?"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/p2_score"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-black"
        android:textSize="24sp"
        android:textColor="#FFFFFF"
        android:text="0"
        android:gravity="end"
        android:layout_marginEnd="8dp"
        app:layout_constraintTop_toTopOf="@id/p2_avatar"
        app:layout_constraintEnd_toStartOf="@id/p2_avatar"/>

    <TextView
        android:id="@+id/p2_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif"
        android:textStyle="bold"
        android:textSize="12sp"
        android:textColor="#FFFFFF"
        android:text="Vukašin"
        android:layout_marginEnd="8dp"
        app:layout_constraintTop_toBottomOf="@id/p2_score"
        app:layout_constraintEnd_toStartOf="@id/p2_avatar"/>

</androidx.constraintlayout.widget.ConstraintLayout>
