<?xml version="1.0" encoding="utf-8"?>
<!-- KO ZNA ZNA · EVROPA · cartoon dizajn
     Java IDs: btnAnswerA, btnAnswerB, btnAnswerC, btnAnswerD, btnSurrender
     Extra IDs (KT2): tvRound, tvQuestion, tvTimer -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_game_evropa">

    <!-- HUD — tamno maroon (eu_3) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#A8312A"
        android:orientation="vertical">
        <include layout="@layout/include_hud"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#60FFFFFF"/>

    <!-- Baner: naziv igre + PREDAJ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#06112A"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingTop="8dp"
        android:paddingEnd="10dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/tvRound"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.04"
            android:text="🏛️ EVROPA · KO ZNA ZNA"
            android:textColor="#FFFFFF"
            android:textSize="14sp"/>

        <Button
            android:id="@+id/btnSurrender"
            style="@style/CartoonButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/btn_cartoon_red"
            android:paddingStart="14dp"
            android:paddingTop="4dp"
            android:paddingEnd="14dp"
            android:paddingBottom="8dp"
            android:text="@string/btn_surrender"
            android:textSize="12sp"/>
    </LinearLayout>

    <!-- Sadržaj -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <!-- Oznaka pitanja -->
        <TextView
            android:id="@+id/tvQuestionLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PITANJE 1 / 5"
            android:fontFamily="sans-serif-black"
            android:textColor="#A8312A"
            android:textSize="13sp"
            android:letterSpacing="0.06"
            android:gravity="center"
            android:layout_marginBottom="8dp"/>

        <!-- Kartica pitanja -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_paper"
            android:padding="16dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:id="@+id/tvQuestion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Koja reka protiče kroz najviše država u Evropi?"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/ink"
                android:textSize="18sp"
                android:lineSpacingMultiplier="1.2"
                android:gravity="center"
                android:minHeight="64dp"/>
        </LinearLayout>

        <!-- 2×2 mreža odgovora -->
        <!-- Red 1: A i B -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <!-- A -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="76dp"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                android:clipChildren="false">

                <Button
                    android:id="@+id/btnAnswerA"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginTop="12dp"
                    style="@style/CartoonButton"
                    android:background="@drawable/btn_cartoon_cream"
                    android:text="RAJNA"
                    android:textColor="@color/ink"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-black"
                    android:gravity="center"
                    android:minHeight="0dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="4dp"/>

                <TextView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="top|center_horizontal"
                    android:text="A"
                    android:gravity="center"
                    android:fontFamily="sans-serif-black"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:background="@drawable/bg_answer_badge"/>
            </FrameLayout>

            <!-- B -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="76dp"
                android:layout_weight="1"
                android:clipChildren="false">

                <Button
                    android:id="@+id/btnAnswerB"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginTop="12dp"
                    style="@style/CartoonButton"
                    android:background="@drawable/btn_cartoon_cream"
                    android:text="DUNAV"
                    android:textColor="@color/ink"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-black"
                    android:gravity="center"
                    android:minHeight="0dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="4dp"/>

                <TextView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="top|center_horizontal"
                    android:text="B"
                    android:gravity="center"
                    android:fontFamily="sans-serif-black"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:background="@drawable/bg_answer_badge"/>
            </FrameLayout>
        </LinearLayout>

        <!-- Red 2: C i D -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <!-- C -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="76dp"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                android:clipChildren="false">

                <Button
                    android:id="@+id/btnAnswerC"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginTop="12dp"
                    style="@style/CartoonButton"
                    android:background="@drawable/btn_cartoon_cream"
                    android:text="VOLGA"
                    android:textColor="@color/ink"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-black"
                    android:gravity="center"
                    android:minHeight="0dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="4dp"/>

                <TextView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="top|center_horizontal"
                    android:text="C"
                    android:gravity="center"
                    android:fontFamily="sans-serif-black"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:background="@drawable/bg_answer_badge"/>
            </FrameLayout>

            <!-- D -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="76dp"
                android:layout_weight="1"
                android:clipChildren="false">

                <Button
                    android:id="@+id/btnAnswerD"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginTop="12dp"
                    style="@style/CartoonButton"
                    android:background="@drawable/btn_cartoon_cream"
                    android:text="SENA"
                    android:textColor="@color/ink"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-black"
                    android:gravity="center"
                    android:minHeight="0dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="4dp"/>

                <TextView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="top|center_horizontal"
                    android:text="D"
                    android:gravity="center"
                    android:fontFamily="sans-serif-black"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:background="@drawable/bg_answer_badge"/>
            </FrameLayout>
        </LinearLayout>

        <!-- Kružni tajmer -->
        <FrameLayout
            android:layout_width="68dp"
            android:layout_height="68dp"
            android:layout_gravity="center_horizontal">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/timer_ring"/>

            <TextView
                android:id="@+id/tvTimer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:fontFamily="sans-serif-black"
                android:textColor="#A8312A"
                android:textSize="22sp"
                android:text="5s"/>
        </FrameLayout>

    </LinearLayout>
</LinearLayout>
