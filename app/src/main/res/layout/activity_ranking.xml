<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_sky_gradient">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_hud"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="48dp"
        android:paddingBottom="14dp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            style="@style/CartoonButton"
            android:paddingTop="4dp"
            android:paddingBottom="8dp"
            android:paddingLeft="0dp"
            android:paddingRight="0dp"
            android:gravity="center"
            android:minHeight="0dp"
            android:text="←"
            android:fontFamily="monospace"
            android:textSize="20sp"
            android:textColor="@color/ink"
            android:background="@drawable/card_paper"
            android:layout_marginEnd="12dp"/>

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_trophy"
            app:tint="#FFD23F"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-black"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:letterSpacing="0.04"
            android:text="@string/label_ranking"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#60FFFFFF"/>

    <!-- Tabovi + opseg datuma -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="10dp"
        android:paddingBottom="6dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnWeekly"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                style="@style/CartoonButton"
                android:paddingTop="4dp"
                android:paddingBottom="8dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:textSize="13sp"
                android:textColor="@color/ink"
                android:text="@string/tab_weekly"
                android:background="@drawable/btn_cartoon_yellow"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnMonthly"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                style="@style/CartoonButton"
                android:paddingTop="4dp"
                android:paddingBottom="8dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:textSize="13sp"
                android:textColor="@color/ink"
                android:text="@string/tab_monthly"
                android:background="@drawable/card_paper"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvCycleRange"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="sans-serif"
            android:textColor="#CCFFFFFF"
            android:textSize="12sp"
            android:text=""/>
    </LinearLayout>

    <!-- Lista ili empty state -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvRanking"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingTop="4dp"
            android:paddingBottom="16dp"/>

        <TextView
            android:id="@+id/tvEmpty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:fontFamily="sans-serif"
            android:textColor="#80FFFFFF"
            android:textSize="14sp"
            android:visibility="gone"
            android:text="@string/ranking_empty"/>
    </FrameLayout>

    <!-- Auto-refresh hint -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingBottom="14dp"
        android:fontFamily="sans-serif"
        android:textColor="#60FFFFFF"
        android:textSize="10sp"
        android:text="@string/ranking_refresh_hint"/>

</LinearLayout>
