<?xml version="1.0" encoding="utf-8"?>
<!-- SKOČKO · J. AMERIKA -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_game_skocko">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_jungle"
        android:scaleType="fitXY"
        android:alpha="0.45"
        android:contentDescription="@null"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#062A1C"
            android:orientation="vertical">
            <include layout="@layout/include_hud"/>
        </LinearLayout>

        <!-- Baner -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#07132E"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp" android:paddingEnd="14dp"
            android:paddingTop="8dp"   android:paddingBottom="8dp">
            <TextView
                android:id="@+id/tvRound"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.06"
                android:text="🦜 J. AMERIKA · SKOČKO"
                android:textAlignment="center"
                android:textColor="#FFFFFF"
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- Main content: board + picker -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:padding="12dp">

            <!-- Board column -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- ── Row 1 ── -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="50dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_empty">
                        <TextView android:id="@+id/tvG1C1" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:textSize="22sp" android:paddingBottom="3dp"/>
                    </FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_empty">
                        <TextView android:id="@+id/tvG1C2" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:textSize="22sp" android:paddingBottom="3dp"/>
                    </FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_empty">
                        <TextView android:id="@+id/tvG1C3" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:textSize="22sp" android:paddingBottom="3dp"/>
                    </FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_empty">
                        <TextView android:id="@+id/tvG1C4" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:textSize="22sp" android:paddingBottom="3dp"/>
                    </FrameLayout>
                    <LinearLayout android:layout_width="36dp" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:layout_marginStart="4dp">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center">
                            <View android:id="@+id/peg1_1" android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                            <View android:id="@+id/peg1_2" android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center">
                            <View android:id="@+id/peg1_3" android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                            <View android:id="@+id/peg1_4" android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- ── Row 2 ── -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="50dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_empty">
                        <TextView android:id="@+id/tvG2C1" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:textSize="22sp" android:paddingBottom="3dp"/>
                    </FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_empty">
                        <TextView android:id="@+id/tvG2C2" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:textSize="22sp" android:paddingBottom="3dp"/>
                    </FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_empty">
                        <TextView android:id="@+id/tvG2C3" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:textSize="22sp" android:paddingBottom="3dp"/>
                    </FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_empty">
                        <TextView android:id="@+id/tvG2C4" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:textSize="22sp" android:paddingBottom="3dp"/>
                    </FrameLayout>
                    <LinearLayout android:layout_width="36dp" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:layout_marginStart="4dp">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center">
                            <View android:id="@+id/peg2_1" android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                            <View android:id="@+id/peg2_2" android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center">
                            <View android:id="@+id/peg2_3" android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                            <View android:id="@+id/peg2_4" android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- ── Row 3 ── -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="50dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_empty">
                        <TextView android:id="@+id/tvG3C1" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:textSize="22sp" android:paddingBottom="3dp"/>
                    </FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_empty">
                        <TextView android:id="@+id/tvG3C2" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:textSize="22sp" android:paddingBottom="3dp"/>
                    </FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_empty">
                        <TextView android:id="@+id/tvG3C3" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:textSize="22sp" android:paddingBottom="3dp"/>
                    </FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_empty">
                        <TextView android:id="@+id/tvG3C4" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:textSize="22sp" android:paddingBottom="3dp"/>
                    </FrameLayout>
                    <LinearLayout android:layout_width="36dp" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:layout_marginStart="4dp">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center">
                            <View android:id="@+id/peg3_1" android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                            <View android:id="@+id/peg3_2" android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center">
                            <View android:id="@+id/peg3_3" android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                            <View android:id="@+id/peg3_4" android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- ── Row 4 ── -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="50dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_empty">
                        <TextView android:id="@+id/tvG4C1" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:textSize="22sp" android:paddingBottom="3dp"/>
                    </FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_empty">
                        <TextView android:id="@+id/tvG4C2" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:textSize="22sp" android:paddingBottom="3dp"/>
                    </FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_empty">
                        <TextView android:id="@+id/tvG4C3" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:textSize="22sp" android:paddingBottom="3dp"/>
                    </FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_empty">
                        <TextView android:id="@+id/tvG4C4" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:textSize="22sp" android:paddingBottom="3dp"/>
                    </FrameLayout>
                    <LinearLayout android:layout_width="36dp" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:layout_marginStart="4dp">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center">
                            <View android:id="@+id/peg4_1" android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                            <View android:id="@+id/peg4_2" android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center">
                            <View android:id="@+id/peg4_3" android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                            <View android:id="@+id/peg4_4" android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- ── Row 5 ── -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="50dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_empty">
                        <TextView android:id="@+id/tvG5C1" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:textSize="22sp" android:paddingBottom="3dp"/>
                    </FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_empty">
                        <TextView android:id="@+id/tvG5C2" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:textSize="22sp" android:paddingBottom="3dp"/>
                    </FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_empty">
                        <TextView android:id="@+id/tvG5C3" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:textSize="22sp" android:paddingBottom="3dp"/>
                    </FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_empty">
                        <TextView android:id="@+id/tvG5C4" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:textSize="22sp" android:paddingBottom="3dp"/>
                    </FrameLayout>
                    <LinearLayout android:layout_width="36dp" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:layout_marginStart="4dp">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center">
                            <View android:id="@+id/peg5_1" android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                            <View android:id="@+id/peg5_2" android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center">
                            <View android:id="@+id/peg5_3" android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                            <View android:id="@+id/peg5_4" android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- ── Row 6 ── -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="50dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_empty">
                        <TextView android:id="@+id/tvG6C1" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:textSize="22sp" android:paddingBottom="3dp"/>
                    </FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_empty">
                        <TextView android:id="@+id/tvG6C2" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:textSize="22sp" android:paddingBottom="3dp"/>
                    </FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_empty">
                        <TextView android:id="@+id/tvG6C3" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:textSize="22sp" android:paddingBottom="3dp"/>
                    </FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_empty">
                        <TextView android:id="@+id/tvG6C4" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:textSize="22sp" android:paddingBottom="3dp"/>
                    </FrameLayout>
                    <LinearLayout android:layout_width="36dp" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:layout_marginStart="4dp">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center">
                            <View android:id="@+id/peg6_1" android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                            <View android:id="@+id/peg6_2" android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center">
                            <View android:id="@+id/peg6_3" android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                            <View android:id="@+id/peg6_4" android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Separator -->
                <View android:layout_width="match_parent" android:layout_height="8dp"/>

                <!-- Opponent row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_skocko_protivnik"
                    android:paddingStart="4dp" android:paddingEnd="4dp"
                    android:paddingTop="3dp"   android:paddingBottom="6dp"
                    android:layout_marginBottom="6dp">
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_filled">
                        <TextView android:id="@+id/tvOppC1" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:textSize="20sp" android:paddingBottom="3dp"/>
                    </FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_filled">
                        <TextView android:id="@+id/tvOppC2" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:textSize="20sp" android:paddingBottom="3dp"/>
                    </FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_filled">
                        <TextView android:id="@+id/tvOppC3" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:textSize="20sp" android:paddingBottom="3dp"/>
                    </FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_filled">
                        <TextView android:id="@+id/tvOppC4" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:textSize="20sp" android:paddingBottom="3dp"/>
                    </FrameLayout>
                    <LinearLayout android:layout_width="36dp" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:layout_marginStart="4dp">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center">
                            <View android:id="@+id/pegOpp_1" android:layout_width="12dp" android:layout_height="12dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                            <View android:id="@+id/pegOpp_2" android:layout_width="12dp" android:layout_height="12dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center">
                            <View android:id="@+id/pegOpp_3" android:layout_width="12dp" android:layout_height="12dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                            <View android:id="@+id/pegOpp_4" android:layout_width="12dp" android:layout_height="12dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Solution row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:background="@drawable/bg_skocko_protivnik"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="4dp" android:paddingEnd="4dp"
                    android:paddingTop="3dp"   android:paddingBottom="6dp">
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_filled">
                        <TextView android:id="@+id/tvSolC1" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:paddingBottom="3dp" android:text="?" android:textColor="@color/sa_3" android:textSize="20sp"/>
                    </FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_filled">
                        <TextView android:id="@+id/tvSolC2" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:paddingBottom="3dp" android:text="?" android:textColor="@color/sa_3" android:textSize="20sp"/>
                    </FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_filled">
                        <TextView android:id="@+id/tvSolC3" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:paddingBottom="3dp" android:text="?" android:textColor="@color/sa_3" android:textSize="20sp"/>
                    </FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_filled">
                        <TextView android:id="@+id/tvSolC4" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:paddingBottom="3dp" android:text="?" android:textColor="@color/sa_3" android:textSize="20sp"/>
                    </FrameLayout>
                    <View android:layout_width="36dp" android:layout_height="1dp" android:layout_marginStart="4dp"/>
                </LinearLayout>

                <!-- Status text -->
                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="RUNDA 1 – TI POGAĐAŠ"
                    android:fontFamily="sans-serif-black"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:letterSpacing="0.04"
                    android:gravity="center"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="4dp"/>

            </LinearLayout>

            <!-- Symbol picker — right strip -->
            <LinearLayout
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_skocko_picker_bg"
                android:padding="6dp"
                android:layout_marginStart="10dp">

                <TextView android:id="@+id/btnSym1"
                    android:layout_width="match_parent" android:layout_height="50dp"
                    android:layout_marginBottom="3dp"
