            android:paddingStart="14dp" android:paddingEnd="14dp"
            android:paddingTop="4dp"   android:paddingBottom="14dp">

            <Button
                android:id="@+id/btnConfirmAttempt"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/CartoonButton"
                android:textSize="20sp"
                android:letterSpacing="0.05"
                android:text="@string/btn_confirm_attempt"
                android:background="@drawable/btn_cartoon_yellow"
