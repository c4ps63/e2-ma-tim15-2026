<?xml version="1.0" encoding="utf-8"?>
<!-- SKOČKO · J. AMERIKA — v4
     Picker = TextView (bez Material tinta)
     PROTIVNIK + REŠENJE = unutar board grida (isti red-format, sa okvirom)
     REŠENJE ćelije = bg_skocko_cell_filled (ista pozadina kao pogađanje)
     Ceo ekran: FLAG_FULLSCREEN u GameActivity, paddingTop=8dp u HUD -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_game_skocko">

    <!-- JungleBg — piramida + džungla (opacity 0.45) -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_jungle"
        android:scaleType="fitXY"
        android:alpha="0.45"
        android:contentDescription="@null"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- HUD oblast — tamnija zelena -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#062A1C"
            android:orientation="vertical">
            <include layout="@layout/include_hud"/>
        </LinearLayout>

        <!-- Baner: J. AMERIKA · SKOČKO (an_3 — tamno plava) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#07132E"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingTop="8dp"
            android:paddingEnd="14dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/tvRound"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.06"
                android:text="🦜 J. AMERIKA · SKOČKO"
                android:textAlignment="center"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- ══════════════════════════════════════════════════════════
             GRID: Board (svi redovi) + Picker desno
             Board sadrži: 6 redova za pogađanje + PROTIVNIK + REŠENJE
             ══════════════════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:padding="12dp">

            <!-- Board — vertikalni stub sa svim redovima -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- ── Red 1 (popunjen: 🦉♣♥★ · hit+near+miss+miss) ── -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="50dp" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_filled">
                        <TextView android:id="@+id/tvG1C1" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="🦉" android:textSize="22sp" android:paddingBottom="3dp"/>
                    </FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_filled">
                        <TextView android:id="@+id/tvG1C2" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="♣" android:textSize="22sp" android:textColor="@color/sa_3" android:paddingBottom="3dp"/>
                    </FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_filled">
                        <TextView android:id="@+id/tvG1C3" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="♥" android:textSize="22sp" android:textColor="#D93A2F" android:paddingBottom="3dp"/>
                    </FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_filled">
                        <TextView android:id="@+id/tvG1C4" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="★" android:textSize="22sp" android:textColor="@color/eu_1" android:paddingBottom="3dp"/>
                    </FrameLayout>
                    <LinearLayout android:layout_width="36dp" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:layout_marginStart="4dp">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center">
                            <View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_hit"/>
                            <View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_near"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center">
                            <View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                            <View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- ── Red 2 (popunjen: ♠♥♦🦉 · hit+hit+near+miss) ── -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="50dp" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_filled">
                        <TextView android:id="@+id/tvG2C1" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="♠" android:textSize="22sp" android:textColor="@color/ink" android:paddingBottom="3dp"/>
                    </FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_filled">
                        <TextView android:id="@+id/tvG2C2" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="♥" android:textSize="22sp" android:textColor="#D93A2F" android:paddingBottom="3dp"/>
                    </FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_filled">
                        <TextView android:id="@+id/tvG2C3" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="♦" android:textSize="22sp" android:textColor="#D93A2F" android:paddingBottom="3dp"/>
                    </FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_filled">
                        <TextView android:id="@+id/tvG2C4" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="🦉" android:textSize="22sp" android:paddingBottom="3dp"/>
                    </FrameLayout>
                    <LinearLayout android:layout_width="36dp" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:layout_marginStart="4dp">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center">
                            <View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_hit"/>
                            <View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_hit"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center">
                            <View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_near"/>
                            <View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- ── Red 3 (prazan) ── -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="50dp" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_empty"><TextView android:id="@+id/tvG3C1" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center"/></FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_empty"><TextView android:id="@+id/tvG3C2" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center"/></FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_empty"><TextView android:id="@+id/tvG3C3" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center"/></FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_empty"><TextView android:id="@+id/tvG3C4" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center"/></FrameLayout>
                    <LinearLayout android:layout_width="36dp" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:layout_marginStart="4dp">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center">
                            <View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                            <View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center">
                            <View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                            <View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- ── Red 4 (prazan) ── -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="50dp" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_empty"><TextView android:id="@+id/tvG4C1" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center"/></FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_empty"><TextView android:id="@+id/tvG4C2" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center"/></FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_empty"><TextView android:id="@+id/tvG4C3" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center"/></FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_empty"><TextView android:id="@+id/tvG4C4" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center"/></FrameLayout>
                    <LinearLayout android:layout_width="36dp" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:layout_marginStart="4dp">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center">
                            <View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                            <View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center">
                            <View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                            <View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- ── Red 5 (prazan) ── -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="50dp" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_empty"><TextView android:id="@+id/tvG5C1" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center"/></FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_empty"><TextView android:id="@+id/tvG5C2" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center"/></FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_empty"><TextView android:id="@+id/tvG5C3" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center"/></FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_empty"><TextView android:id="@+id/tvG5C4" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center"/></FrameLayout>
                    <LinearLayout android:layout_width="36dp" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:layout_marginStart="4dp">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center">
                            <View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                            <View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center">
                            <View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                            <View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- ── Red 6 (prazan) ── -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="50dp" android:orientation="horizontal" android:gravity="center_vertical">
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_empty"><TextView android:id="@+id/tvG6C1" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center"/></FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_empty"><TextView android:id="@+id/tvG6C2" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center"/></FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_empty"><TextView android:id="@+id/tvG6C3" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center"/></FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_empty"><TextView android:id="@+id/tvG6C4" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center"/></FrameLayout>
                    <LinearLayout android:layout_width="36dp" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:layout_marginStart="4dp">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center">
                            <View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                            <View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center">
                            <View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                            <View android:layout_width="14dp" android:layout_height="14dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- ═══ SEPARATOR ═══ -->
                <View android:layout_width="match_parent" android:layout_height="8dp"/>

                <!-- ── PROTIVNIK red — isti grid, okvir bg_skocko_protivnik ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_skocko_protivnik"
                    android:paddingStart="4dp" android:paddingEnd="4dp"
                    android:paddingTop="3dp" android:paddingBottom="6dp"
                    android:layout_marginBottom="6dp">
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_filled">
                        <TextView android:id="@+id/tvOppC1" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="🦉" android:textSize="20sp" android:paddingBottom="3dp"/>
                    </FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_filled">
                        <TextView android:id="@+id/tvOppC2" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="♣" android:textSize="20sp" android:textColor="@color/sa_3" android:paddingBottom="3dp"/>
                    </FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_filled">
                        <TextView android:id="@+id/tvOppC3" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="♥" android:textSize="20sp" android:textColor="#D93A2F" android:paddingBottom="3dp"/>
                    </FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:background="@drawable/bg_skocko_cell_filled">
                        <TextView android:id="@+id/tvOppC4" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="★" android:textSize="20sp" android:textColor="@color/eu_1" android:paddingBottom="3dp"/>
                    </FrameLayout>
                    <!-- Peg area (poravnanje sa redovima pogađanja) -->
                    <LinearLayout android:layout_width="36dp" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:layout_marginStart="4dp">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center">
                            <View android:layout_width="12dp" android:layout_height="12dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_hit"/>
                            <View android:layout_width="12dp" android:layout_height="12dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center">
                            <View android:layout_width="12dp" android:layout_height="12dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                            <View android:layout_width="12dp" android:layout_height="12dp" android:layout_margin="1dp" android:background="@drawable/bg_peg_miss"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- ── REŠENJE red — isti grid, okvir bg_skocko_resenje, iste ćelije ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:background="@drawable/bg_skocko_protivnik"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="4dp"
                    android:paddingTop="3dp"
                    android:paddingEnd="4dp"
                    android:paddingBottom="6dp">

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_margin="2dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_skocko_cell_filled">

                        <TextView
                            android:id="@+id/tvSolC1"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:paddingBottom="3dp"
                            android:text="?"
                            android:textColor="@color/sa_3"
                            android:textSize="20sp" />
                    </FrameLayout>

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_margin="2dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_skocko_cell_filled">

                        <TextView
                            android:id="@+id/tvSolC2"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:paddingBottom="3dp"
                            android:text="?"
                            android:textColor="@color/sa_3"
                            android:textSize="20sp" />
                    </FrameLayout>

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_margin="2dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_skocko_cell_filled">

                        <TextView
                            android:id="@+id/tvSolC3"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:paddingBottom="3dp"
                            android:text="?"
                            android:textColor="@color/sa_3"
                            android:textSize="20sp" />
                    </FrameLayout>

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_margin="2dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_skocko_cell_filled">

                        <TextView
                            android:id="@+id/tvSolC4"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:paddingBottom="3dp"
                            android:text="?"
                            android:textColor="@color/sa_3"
                            android:textSize="20sp" />
                    </FrameLayout>
                    <!-- Spacer za poravnanje sa peg kolonom -->
                    <View
                        android:layout_width="36dp"
                        android:layout_height="1dp"
                        android:layout_marginStart="4dp" />
                </LinearLayout>

            </LinearLayout>

            <!-- ════════════════════════════════════
                 PICKER SIMBOLA — desna traka (64dp)
                 TextView umesto Button (nema Material tinta)
                 6×50dp, semi-transparent okvir
                 ════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_skocko_picker_bg"
                android:padding="6dp"
                android:layout_marginStart="10dp">

                <TextView android:id="@+id/btnSym1"
                    android:layout_width="match_parent" android:layout_height="50dp"
