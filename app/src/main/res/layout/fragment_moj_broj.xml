<?xml version="1.0" encoding="utf-8"?>
<!--
  MOJ BROJ · AUSTRALIJA · cartoon dizajn v5
  - HUD pozadina = au_3 (tamno) da se razlikuje od svetlog gradijenta
  - "DOĐI DO BROJA" i "743" centrirani horizontalno
  - Operatori: monospace font + textDirection=ltr (garantovani glifi)
  Java IDs: tvExpression (EditText), btnConfirm, btnReset, btnSurrender
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_game_australia">

    <!-- ── HUD — tamna pozadina au_3 da kontrastira s gradijentom ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/au_3"
        android:orientation="vertical">
        <include layout="@layout/include_hud"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#60FFFFFF"/>

    <!-- ── Sadržaj ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="22dp"
        android:paddingBottom="44dp">

        <!-- Natpis "DOĐI DO BROJA" — centar -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:fontFamily="sans-serif-black"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:letterSpacing="0.12"
            android:layout_marginBottom="12dp"
            android:text="DOĐI DO BROJA"/>

        <!-- Ciljni broj — krem karta, centrirana -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/bg_expression_display"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingTop="8dp"
            android:paddingBottom="14dp"
            android:layout_marginBottom="14dp">
            <TextView
                android:id="@+id/tvTarget"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/au_1"
                android:textSize="40sp"
                android:includeFontPadding="false"
                android:text="743"/>
        </LinearLayout>

        <!-- Polja za rezultate igrača — prikazuju ??? dok se ne potvrdi rešenje -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tvPlayerResult"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:gravity="center"
                android:fontFamily="sans-serif-black"
                android:textColor="#FFFFFF"
                android:textSize="19sp"
                android:includeFontPadding="false"
                android:paddingTop="2dp"
                android:paddingBottom="6dp"
                android:background="@drawable/btn_cartoon_blue"
                android:text="@string/result_pending"/>

            <TextView
                android:id="@+id/tvOpponentResult"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:gravity="center"
                android:fontFamily="sans-serif-black"
                android:textColor="#FFFFFF"
                android:textSize="19sp"
                android:includeFontPadding="false"
                android:paddingTop="2dp"
                android:paddingBottom="6dp"
                android:background="@drawable/btn_cartoon_red"
                android:text="@string/result_pending"/>
        </LinearLayout>

        <!-- Spacer: ~0.5x od paddingBottom, blok je srednje pozicioniran -->
        <View
            android:layout_width="match_parent"
            android:layout_height="50dp"/>

        <!-- Hint: vidljiv samo dok se brojevi vrte (kontroliše Java) -->
        <TextView
            android:id="@+id/tvShakeHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:fontFamily="sans-serif-black"
            android:textColor="@color/eu_1"
            android:textSize="11sp"
            android:letterSpacing="0.06"
            android:layout_marginBottom="8dp"
            android:visibility="gone"
            android:text="🤳  PROTRESI TELEFON ZA STOP"/>

        <!-- Izraz koji igrač gradi + inline X dugme za brisanje -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_expression_display"
            android:paddingStart="14dp"
            android:paddingEnd="6dp"
            android:paddingBottom="5dp"
            android:layout_marginBottom="10dp">

            <EditText
                android:id="@+id/tvExpression"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/ink"
                android:textSize="20sp"
                android:hint="25 × 8 + …"
                android:inputType="none"
                android:focusable="false"
                android:gravity="center_vertical"/>

            <!-- ⌫ briše zadnji token -->
            <Button
                android:id="@+id/btnBackspace"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center_vertical"
                android:layout_marginEnd="4dp"
                style="@style/CartoonButton"
                android:fontFamily="monospace"
                android:text="&#9003;"
                android:textSize="16sp"
                android:textColor="@color/ink_dark"
                android:background="@drawable/bg_tile_operator"
                android:paddingTop="0dp"
                android:paddingBottom="3dp"
                android:paddingLeft="0dp"
                android:paddingRight="0dp"
                android:gravity="center"
                android:minHeight="0dp"/>

            <!-- ✕ briše ceo izraz -->
            <Button
                android:id="@+id/btnReset"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center_vertical"
                style="@style/CartoonButton"
                android:fontFamily="monospace"
                android:text="&#10005;"
                android:textSize="18sp"
                android:textColor="@color/ink_dark"
                android:background="@drawable/bg_tile_operator"
                android:paddingTop="0dp"
                android:paddingBottom="3dp"
                android:paddingLeft="0dp"
                android:paddingRight="0dp"
                android:gravity="center"
                android:minHeight="0dp"/>
        </LinearLayout>

        <!-- ── Kontejner za pločice ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_numbers_container"
            android:padding="12dp"
            android:layout_marginBottom="12dp">

            <!-- Red 1: 4 jednocifarna broja -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">
                <Button android:id="@+id/btnNum0"
                    android:layout_width="56dp" android:layout_height="56dp"
                    android:layout_margin="4dp" style="@style/CartoonButton"
                    android:text="?" android:background="@drawable/bg_tile_number"
                    android:textColor="@color/ink" android:textSize="19sp"/>
                <Button android:id="@+id/btnNum1"
                    android:layout_width="56dp" android:layout_height="56dp"
                    android:layout_margin="4dp" style="@style/CartoonButton"
                    android:text="?" android:background="@drawable/bg_tile_number"
                    android:textColor="@color/ink" android:textSize="19sp"/>
                <Button android:id="@+id/btnNum2"
                    android:layout_width="56dp" android:layout_height="56dp"
                    android:layout_margin="4dp" style="@style/CartoonButton"
                    android:text="?" android:background="@drawable/bg_tile_number"
                    android:textColor="@color/ink" android:textSize="19sp"/>
                <Button android:id="@+id/btnNum3"
                    android:layout_width="56dp" android:layout_height="56dp"
                    android:layout_margin="4dp" style="@style/CartoonButton"
                    android:text="?" android:background="@drawable/bg_tile_number"
                    android:textColor="@color/ink" android:textSize="19sp"/>
            </LinearLayout>

            <!-- Red 2: srednji (10/15/20) i veliki (25/50/75/100) broj -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="4dp">
                <Button android:id="@+id/btnNum4"
                    android:layout_width="0dp" android:layout_height="56dp"
                    android:layout_weight="1" android:layout_margin="4dp"
                    style="@style/CartoonButton"
                    android:text="?" android:background="@drawable/bg_tile_number"
                    android:textColor="@color/ink" android:textSize="19sp"/>
                <Button android:id="@+id/btnNum5"
                    android:layout_width="0dp" android:layout_height="56dp"
                    android:layout_weight="1" android:layout_margin="4dp"
                    style="@style/CartoonButton"
                    android:text="?" android:background="@drawable/bg_tile_number"
                    android:textColor="@color/ink" android:textSize="19sp"/>
            </LinearLayout>

            <!--
              Red 3: Operatori
              paddingTop/Bottom su eksplicitno mali da tekst ne bude presečen
              (CartoonButton stil ima prevelike padinge za ove male pločice)
            -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="6dp">

                <Button android:id="@+id/btnOpAdd"
                    android:layout_width="46dp" android:layout_height="46dp"
                    android:layout_margin="3dp" style="@style/CartoonButton"
                    android:fontFamily="monospace" android:textDirection="ltr"
                    android:paddingTop="0dp" android:paddingBottom="3dp"
                    android:paddingLeft="0dp" android:paddingRight="0dp"
                    android:gravity="center" android:minHeight="0dp"
                    android:text="+" android:background="@drawable/bg_tile_operator"
                    android:textColor="@color/ink_dark" android:textSize="22sp"/>
                <Button android:id="@+id/btnOpSub"
                    android:layout_width="46dp" android:layout_height="46dp"
                    android:layout_margin="3dp" style="@style/CartoonButton"
                    android:fontFamily="monospace" android:textDirection="ltr"
                    android:paddingTop="0dp" android:paddingBottom="3dp"
                    android:paddingLeft="0dp" android:paddingRight="0dp"
                    android:gravity="center" android:minHeight="0dp"
                    android:text="&#8722;" android:background="@drawable/bg_tile_operator"
                    android:textColor="@color/ink_dark" android:textSize="22sp"/>
                <Button android:id="@+id/btnOpMul"
                    android:layout_width="46dp" android:layout_height="46dp"
                    android:layout_margin="3dp" style="@style/CartoonButton"
                    android:fontFamily="monospace" android:textDirection="ltr"
                    android:paddingTop="0dp" android:paddingBottom="3dp"
                    android:paddingLeft="0dp" android:paddingRight="0dp"
                    android:gravity="center" android:minHeight="0dp"
                    android:text="&#215;" android:background="@drawable/bg_tile_operator"
                    android:textColor="@color/ink_dark" android:textSize="22sp"/>
                <Button android:id="@+id/btnOpDiv"
                    android:layout_width="46dp" android:layout_height="46dp"
                    android:layout_margin="3dp" style="@style/CartoonButton"
                    android:fontFamily="monospace" android:textDirection="ltr"
                    android:paddingTop="0dp" android:paddingBottom="3dp"
                    android:paddingLeft="0dp" android:paddingRight="0dp"
                    android:gravity="center" android:minHeight="0dp"
                    android:text="&#247;" android:background="@drawable/bg_tile_operator"
                    android:textColor="@color/ink_dark" android:textSize="22sp"/>
                <Button android:id="@+id/btnOpOpen"
                    android:layout_width="46dp" android:layout_height="46dp"
                    android:layout_margin="3dp" style="@style/CartoonButton"
                    android:fontFamily="monospace" android:textDirection="ltr"
                    android:paddingTop="0dp" android:paddingBottom="3dp"
                    android:paddingLeft="0dp" android:paddingRight="0dp"
                    android:gravity="center" android:minHeight="0dp"
                    android:text="(" android:background="@drawable/bg_tile_operator"
                    android:textColor="@color/ink_dark" android:textSize="22sp"/>
                <Button android:id="@+id/btnOpClose"
                    android:layout_width="46dp" android:layout_height="46dp"
                    android:layout_margin="3dp" style="@style/CartoonButton"
                    android:fontFamily="monospace" android:textDirection="ltr"
                    android:paddingTop="0dp" android:paddingBottom="3dp"
                    android:paddingLeft="0dp" android:paddingRight="0dp"
                    android:gravity="center" android:minHeight="0dp"
                    android:text=")" android:background="@drawable/bg_tile_operator"
                    android:textColor="@color/ink_dark" android:textSize="22sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Predaj — skriven, ID ostaje za kasniju implementaciju app-wide -->
        <Button
            android:id="@+id/btnSurrender"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"/>

        <!-- Potvrdi — skroz dole ispod svih pločica -->
        <Button
            android:id="@+id/btnConfirm"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            style="@style/CartoonButton"
            android:textSize="20sp"
            android:text="@string/btn_confirm"
            android:background="@drawable/btn_cartoon_yellow"
            android:textColor="@color/ink"
            android:layout_marginTop="6dp"/>

    </LinearLayout>
</LinearLayout>
