<?xml version="1.0" encoding="utf-8"?>
<!-- SPOJNICE · AZIJA · cartoon dizajn
     Java IDs: btnConfirm (PRESKOČI), btnSurrender (ODUSTANI)
     Extra IDs (KT2): tvRound, tvLeft1-5, tvRight1-5, connector1-5 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_game_azija">

    <!-- HUD — tamno (as_3) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#7A1F3D"
        android:orientation="vertical">
        <include layout="@layout/include_hud"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#60FFFFFF"/>

    <!-- Baner: naziv igre -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#06112A"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingTop="8dp"
        android:paddingEnd="14dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/tvRound"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.04"
            android:text="🏮 AZIJA · SPOJNICE"
            android:textAlignment="center"
            android:textColor="#FFFFFF"
            android:textSize="14sp"/>
    </LinearLayout>

    <!-- Sadržaj -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="14dp"
        android:paddingBottom="10dp">

        <!-- Red 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <Button
                android:id="@+id/tvLeft1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                style="@style/CartoonButton"
                android:background="@drawable/btn_cartoon_salmon"
                android:text="Tokio"
                android:textColor="@color/ink"
                android:textSize="14sp"
                android:fontFamily="sans-serif-black"
                android:gravity="center"
                android:minHeight="0dp"
                android:paddingTop="4dp"
                android:paddingBottom="8dp"
                android:layout_marginEnd="4dp"/>

            <View
                android:id="@+id/connector1"
                android:layout_width="20dp"
                android:layout_height="4dp"
                android:background="#2D9A4A"
                android:visibility="invisible"/>

            <Button
                android:id="@+id/tvRight1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                style="@style/CartoonButton"
                android:background="@drawable/btn_cartoon_salmon"
                android:text="Tajland"
                android:textColor="@color/ink"
                android:textSize="14sp"
                android:fontFamily="sans-serif-black"
                android:gravity="center"
                android:minHeight="0dp"
                android:paddingTop="4dp"
                android:paddingBottom="8dp"
                android:layout_marginStart="4dp"/>
        </LinearLayout>

        <!-- Red 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <Button
                android:id="@+id/tvLeft2"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                style="@style/CartoonButton"
                android:background="@drawable/btn_cartoon_salmon"
                android:text="Peking"
                android:textColor="@color/ink"
                android:textSize="14sp"
                android:fontFamily="sans-serif-black"
                android:gravity="center"
                android:minHeight="0dp"
                android:paddingTop="4dp"
                android:paddingBottom="8dp"
                android:layout_marginEnd="4dp"/>

            <View
                android:id="@+id/connector2"
                android:layout_width="20dp"
                android:layout_height="4dp"
                android:background="#2D9A4A"
                android:visibility="invisible"/>

            <Button
                android:id="@+id/tvRight2"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                style="@style/CartoonButton"
                android:background="@drawable/btn_cartoon_salmon"
                android:text="Kina"
                android:textColor="@color/ink"
                android:textSize="14sp"
                android:fontFamily="sans-serif-black"
                android:gravity="center"
                android:minHeight="0dp"
                android:paddingTop="4dp"
                android:paddingBottom="8dp"
                android:layout_marginStart="4dp"/>
        </LinearLayout>

        <!-- Red 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <Button
                android:id="@+id/tvLeft3"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                style="@style/CartoonButton"
                android:background="@drawable/btn_cartoon_salmon"
                android:text="Seul"
                android:textColor="@color/ink"
                android:textSize="14sp"
                android:fontFamily="sans-serif-black"
                android:gravity="center"
                android:minHeight="0dp"
                android:paddingTop="4dp"
                android:paddingBottom="8dp"
                android:layout_marginEnd="4dp"/>

            <View
                android:id="@+id/connector3"
                android:layout_width="20dp"
                android:layout_height="4dp"
                android:background="#2D9A4A"
                android:visibility="invisible"/>

            <Button
                android:id="@+id/tvRight3"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                style="@style/CartoonButton"
                android:background="@drawable/btn_cartoon_salmon"
                android:text="Vijetnam"
                android:textColor="@color/ink"
                android:textSize="14sp"
                android:fontFamily="sans-serif-black"
                android:gravity="center"
                android:minHeight="0dp"
                android:paddingTop="4dp"
                android:paddingBottom="8dp"
                android:layout_marginStart="4dp"/>
        </LinearLayout>

        <!-- Red 4 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <Button
                android:id="@+id/tvLeft4"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                style="@style/CartoonButton"
                android:background="@drawable/btn_cartoon_salmon"
                android:text="Bangkok"
                android:textColor="@color/ink"
                android:textSize="14sp"
                android:fontFamily="sans-serif-black"
                android:gravity="center"
                android:minHeight="0dp"
                android:paddingTop="4dp"
                android:paddingBottom="8dp"
                android:layout_marginEnd="4dp"/>

            <View
                android:id="@+id/connector4"
                android:layout_width="20dp"
                android:layout_height="4dp"
                android:background="#2D9A4A"
                android:visibility="invisible"/>

            <Button
                android:id="@+id/tvRight4"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                style="@style/CartoonButton"
                android:background="@drawable/btn_cartoon_salmon"
                android:text="Japan"
                android:textColor="@color/ink"
                android:textSize="14sp"
                android:fontFamily="sans-serif-black"
                android:gravity="center"
                android:minHeight="0dp"
                android:paddingTop="4dp"
                android:paddingBottom="8dp"
                android:layout_marginStart="4dp"/>
        </LinearLayout>

        <!-- Red 5 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="14dp">

            <Button
                android:id="@+id/tvLeft5"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                style="@style/CartoonButton"
                android:background="@drawable/btn_cartoon_salmon"
                android:text="Hanoi"
                android:textColor="@color/ink"
                android:textSize="14sp"
                android:fontFamily="sans-serif-black"
                android:gravity="center"
                android:minHeight="0dp"
                android:paddingTop="4dp"
                android:paddingBottom="8dp"
                android:layout_marginEnd="4dp"/>

            <View
                android:id="@+id/connector5"
                android:layout_width="20dp"
                android:layout_height="4dp"
                android:background="#2D9A4A"
                android:visibility="invisible"/>

            <Button
                android:id="@+id/tvRight5"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                style="@style/CartoonButton"
                android:background="@drawable/btn_cartoon_salmon"
                android:text="J. Koreja"
                android:textColor="@color/ink"
                android:textSize="14sp"
                android:fontFamily="sans-serif-black"
                android:gravity="center"
                android:minHeight="0dp"
                android:paddingTop="4dp"
                android:paddingBottom="8dp"
                android:layout_marginStart="4dp"/>
        </LinearLayout>

        <!-- Status tekst -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="RUNDA 1 – POVEZANO 0/5"
            android:fontFamily="sans-serif-black"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:letterSpacing="0.04"
            android:gravity="center"
            android:layout_marginBottom="12dp"/>

        <!-- Dugmad: PRESKOČI + ODUSTANI -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnConfirm"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/CartoonButton"
                android:background="@drawable/btn_cartoon_yellow"
                android:text="PRESKOČI"
                android:textColor="@color/ink"
                android:textSize="16sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.04"
                android:paddingTop="6dp"
                android:paddingBottom="12dp"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnSurrender"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/CartoonButton"
                android:background="@drawable/btn_cartoon_red"
                android:text="ODUSTANI"
                android:textSize="16sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.04"
                android:paddingTop="6dp"
                android:paddingBottom="12dp"/>
        </LinearLayout>

    </LinearLayout>
</LinearLayout>
