<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="@drawable/bg_sky_gradient">

    <!-- ── Čekanje na finalu (vidljivo samo polufinalistu-pobedniku) ── -->
    <LinearLayout
        android:id="@+id/layoutWaiting"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="52sp"
            android:text="🏆"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="sans-serif-black"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:gravity="center"
            android:shadowColor="#80000000"
            android:shadowDy="2"
            android:shadowRadius="4"
            android:text="@string/tournament_advanced"/>

        <TextView
            android:id="@+id/tvWaitingDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="sans-serif"
            android:textColor="#CCFFFFFF"
            android:textSize="14sp"
            android:gravity="center"
            android:text="@string/tournament_waiting_final"/>

        <!-- Rewards earned in semi -->
        <LinearLayout
            android:id="@+id/semiRewardCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/card_paper"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingTop="12dp"
            android:paddingBottom="14dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_glyph_diamond"
                app:tint="#39B6FF"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:id="@+id/tvSemiReward"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/ink"
                android:textSize="14sp"
                android:text="+2 žetona"/>

            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_glyph_star"
                app:tint="#FFD23F"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:id="@+id/tvSemiStars"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/ink"
                android:textSize="14sp"
                android:text=""/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:fontFamily="sans-serif"
            android:textColor="#AAFFFFFF"
            android:textSize="12sp"
            android:gravity="center"
            android:text="@string/tournament_waiting_hint"/>
    </LinearLayout>

    <!-- ── Rezultat (pobeda ili poraz u finalu / poraz u polufinalu) ── -->
    <LinearLayout
        android:id="@+id/layoutResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvResultEmoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="64sp"
            android:text="🏆"/>

        <TextView
            android:id="@+id/tvResultTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="sans-serif-black"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:gravity="center"
            android:shadowColor="#80000000"
            android:shadowDy="2"
            android:shadowRadius="4"
            android:text="POBEDA!"/>

        <TextView
            android:id="@+id/tvResultDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="sans-serif"
            android:textColor="#CCFFFFFF"
            android:textSize="14sp"
            android:gravity="center"
            android:text=""/>

        <!-- Reward card -->
        <LinearLayout
            android:id="@+id/rewardCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/card_paper"
            android:orientation="vertical"
            android:paddingTop="12dp"
            android:paddingBottom="14dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/ink"
                android:alpha="0.5"
                android:textSize="10sp"
                android:letterSpacing="0.06"
                android:text="NAGRADE"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:gravity="center">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_glyph_diamond"
                    app:tint="#39B6FF"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    android:id="@+id/tvRewardTokens"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:textColor="@color/ink"
                    android:textSize="15sp"
                    android:text="+3 žetona"/>

                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_glyph_star"
                    app:tint="#FFD23F"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    android:id="@+id/tvRewardStars"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:textColor="@color/ink"
                    android:textSize="15sp"
                    android:text=""/>
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/btnHome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:background="@drawable/btn_cartoon_green"
            android:fontFamily="sans-serif-black"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:paddingTop="14dp"
            android:paddingBottom="18dp"
            android:text="@string/tournament_go_home"/>
    </LinearLayout>

</LinearLayout>
