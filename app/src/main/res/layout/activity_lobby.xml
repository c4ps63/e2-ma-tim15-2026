<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="@drawable/bg_sky_gradient">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔍"
        android:textSize="64sp"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/tvLobbyStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tražim protivnika..."
        android:fontFamily="sans-serif-black"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:gravity="center"
        android:layout_marginBottom="16dp"/>

    <ProgressBar
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminate="true"
        android:indeterminateTint="#FFD23F"
        android:layout_marginBottom="48dp"/>

    <Button
        android:id="@+id/btnLobbyCancel"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="OTKAŽI"
        android:fontFamily="sans-serif-black"
        android:background="@drawable/btn_cartoon_red"/>

</LinearLayout>
