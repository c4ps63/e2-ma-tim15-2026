<?xml version="1.0" encoding="utf-8"?>
<!-- Jedan red u listi notifikacija -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/card_paper"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginBottom="10dp"
    android:clickable="true"
    android:focusable="true">

    <!-- Obojena leva traka (boja kanala) -->
    <View
        android:id="@+id/viewChannelBar"
        android:layout_width="5dp"
        android:layout_height="match_parent"
        android:minHeight="72dp"
        android:background="@color/sky_light"/>

    <!-- Sadržaj -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="8dp">

        <!-- Red: kanal chip + vreme + tačka nepročitanog -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/tvChannelChip"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:fontFamily="sans-serif-black"
                android:textSize="9sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/btn_cartoon_blue"
                android:gravity="center"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="4dp"
                android:layout_marginEnd="8dp"
                android:text="ČET"/>

            <TextView
                android:id="@+id/tvTime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="sans-serif"
                android:textSize="10sp"
                android:textColor="@color/ink"
                android:alpha="0.5"
                android:gravity="end"
                android:text="pre 2 min"/>

            <!-- Tačka nepročitanog -->
            <View
                android:id="@+id/viewUnreadDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/btn_cartoon_red"
                android:visibility="visible"/>
        </LinearLayout>

        <!-- Naslov -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:textSize="13sp"
            android:textColor="@color/ink"
            android:layout_marginBottom="2dp"
            android:text="Naslov"/>

        <!-- Telo -->
        <TextView
            android:id="@+id/tvBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif"
            android:textSize="11sp"
            android:textColor="@color/ink"
            android:alpha="0.6"
            android:text="Opis notifikacije"/>

        <!-- Akcija (opciono, za nepročitane sa action) -->
        <Button
            android:id="@+id/btnAction"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:layout_marginTop="6dp"
            style="@style/CartoonButton"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="2dp"
            android:paddingBottom="6dp"
            android:textSize="10sp"
            android:textColor="@color/ink"
            android:background="@drawable/btn_cartoon_yellow"
            android:text="OTVORI"
            android:visibility="gone"/>

    </LinearLayout>

</LinearLayout>
