<?xml version="1.0" encoding="utf-8"?>
<!--
  KORAK PO KORAK · S. AMERIKA · cartoon dizajn v6
  Staircase: svi koraci ISTE dužine, svaki pomeren desno za 6dp.
    Start = (N-1)*6dp,  End = (7-N)*6dp   → širina = container - 36dp (konstantna)
  Dekorativni oval u pozadini ScrollView oblasti.
  Java IDs: etAnswer, btnConfirm, btnDelete, btnSurrender
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_game_n_america">

    <!-- ── HUD — tamna pozadina na_3 ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/na_3"
        android:orientation="vertical">
        <include layout="@layout/include_hud"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#60FFFFFF"/>

    <!-- ── Header: debela narandžasta slova, braon kontura ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:fontFamily="sans-serif-black"
            android:textColor="@color/eu_1"
            android:textSize="18sp"
            android:letterSpacing="0.05"
            android:shadowColor="@color/na_3"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="9"
            android:text="PRONAĐI POJAM"/>

        <TextView
            android:id="@+id/tvRound"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:fontFamily="sans-serif-black"
            android:textColor="#FFD89A"
            android:textSize="12sp"
            android:letterSpacing="0.04"
            android:shadowColor="@color/na_3"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="7"
            android:text="KORAK 4/7  ·  MAX 14 BODOVA"/>
    </LinearLayout>

    <!-- ── Scrollable zona: dekorativni oval + koraci ── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never"
        android:fillViewport="false">

        <!-- FrameLayout za slojevitost: oval iza, koraci ispred -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Koraci — ista širina (container−36dp), pomereni desno za 6dp po koraku -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="10dp"
                android:paddingBottom="4dp">

                <!-- ══ KORAK 1 ══ -->
                <LinearLayout android:id="@+id/stepRow1"
                    android:layout_width="match_parent" android:layout_height="58dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:background="@drawable/bg_step_locked"
                    android:paddingStart="10dp" android:paddingEnd="12dp"
                    android:layout_marginStart="0dp" android:layout_marginEnd="36dp"
                    android:layout_marginBottom="4dp">
                    <FrameLayout android:layout_width="28dp" android:layout_height="28dp"
                        android:background="@drawable/bg_step_number_circle" android:layout_marginEnd="10dp">
                        <TextView android:layout_width="match_parent" android:layout_height="match_parent"
                            android:gravity="center" android:fontFamily="sans-serif-black"
                            android:textColor="#FFFFFF" android:textSize="13sp" android:text="1"/>
                    </FrameLayout>
                    <TextView android:id="@+id/tvClue1"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:fontFamily="sans-serif-black"
                        android:textColor="#80000000" android:textSize="13sp" android:text="—  ZAKLJUČAN  —"/>
                    <TextView android:id="@+id/tvPoints1"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black" android:textColor="#80000000"
                        android:textSize="12sp" android:text="20★"/>
                </LinearLayout>

                <!-- ══ KORAK 2 ══ -->
                <LinearLayout android:id="@+id/stepRow2"
                    android:layout_width="match_parent" android:layout_height="58dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:background="@drawable/bg_step_locked"
                    android:paddingStart="10dp" android:paddingEnd="12dp"
                    android:layout_marginStart="6dp" android:layout_marginEnd="30dp"
                    android:layout_marginBottom="4dp">
                    <FrameLayout android:layout_width="28dp" android:layout_height="28dp"
                        android:background="@drawable/bg_step_number_circle" android:layout_marginEnd="10dp">
                        <TextView android:layout_width="match_parent" android:layout_height="match_parent"
                            android:gravity="center" android:fontFamily="sans-serif-black"
                            android:textColor="#FFFFFF" android:textSize="13sp" android:text="2"/>
                    </FrameLayout>
                    <TextView android:id="@+id/tvClue2"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:fontFamily="sans-serif-black"
                        android:textColor="#80000000" android:textSize="13sp" android:text="—  ZAKLJUČAN  —"/>
                    <TextView android:id="@+id/tvPoints2"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black" android:textColor="#80000000"
                        android:textSize="12sp" android:text="18★"/>
                </LinearLayout>

                <!-- ══ KORAK 3 ══ -->
                <LinearLayout android:id="@+id/stepRow3"
                    android:layout_width="match_parent" android:layout_height="58dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:background="@drawable/bg_step_locked"
                    android:paddingStart="10dp" android:paddingEnd="12dp"
                    android:layout_marginStart="12dp" android:layout_marginEnd="24dp"
                    android:layout_marginBottom="4dp">
                    <FrameLayout android:layout_width="28dp" android:layout_height="28dp"
                        android:background="@drawable/bg_step_number_circle" android:layout_marginEnd="10dp">
                        <TextView android:layout_width="match_parent" android:layout_height="match_parent"
                            android:gravity="center" android:fontFamily="sans-serif-black"
                            android:textColor="#FFFFFF" android:textSize="13sp" android:text="3"/>
                    </FrameLayout>
                    <TextView android:id="@+id/tvClue3"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:fontFamily="sans-serif-black"
                        android:textColor="#80000000" android:textSize="13sp" android:text="—  ZAKLJUČAN  —"/>
                    <TextView android:id="@+id/tvPoints3"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black" android:textColor="#80000000"
                        android:textSize="12sp" android:text="16★"/>
                </LinearLayout>

                <!-- ══ KORAK 4 ══ -->
                <LinearLayout android:id="@+id/stepRow4"
                    android:layout_width="match_parent" android:layout_height="58dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:background="@drawable/bg_step_locked"
                    android:paddingStart="10dp" android:paddingEnd="12dp"
                    android:layout_marginStart="18dp" android:layout_marginEnd="18dp"
                    android:layout_marginBottom="4dp">
                    <FrameLayout android:layout_width="28dp" android:layout_height="28dp"
                        android:background="@drawable/bg_step_number_circle" android:layout_marginEnd="10dp">
                        <TextView android:layout_width="match_parent" android:layout_height="match_parent"
                            android:gravity="center" android:fontFamily="sans-serif-black"
                            android:textColor="#FFFFFF" android:textSize="13sp" android:text="4"/>
                    </FrameLayout>
                    <TextView android:id="@+id/tvClue4"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:fontFamily="sans-serif-black"
                        android:textColor="#80000000" android:textSize="13sp" android:text="—  ZAKLJUČAN  —"/>
                    <TextView android:id="@+id/tvPoints4"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black" android:textColor="#80000000"
                        android:textSize="12sp" android:text="14★"/>
                </LinearLayout>

                <!-- ══ KORAK 5 ══ -->
                <LinearLayout android:id="@+id/stepRow5"
                    android:layout_width="match_parent" android:layout_height="58dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:background="@drawable/bg_step_locked"
                    android:paddingStart="10dp" android:paddingEnd="12dp"
                    android:layout_marginStart="24dp" android:layout_marginEnd="12dp"
                    android:layout_marginBottom="4dp">
                    <FrameLayout android:layout_width="28dp" android:layout_height="28dp"
                        android:background="@drawable/bg_step_number_circle" android:layout_marginEnd="10dp">
                        <TextView android:layout_width="match_parent" android:layout_height="match_parent"
                            android:gravity="center" android:fontFamily="sans-serif-black"
                            android:textColor="#FFFFFF" android:textSize="13sp" android:text="5"/>
                    </FrameLayout>
                    <TextView android:id="@+id/tvClue5"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:fontFamily="sans-serif-black"
                        android:textColor="#80000000" android:textSize="13sp" android:text="—  ZAKLJUČAN  —"/>
                    <TextView android:id="@+id/tvPoints5"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black" android:textColor="#80000000"
                        android:textSize="12sp" android:text="12★"/>
                </LinearLayout>

                <!-- ══ KORAK 6 ══ -->
                <LinearLayout android:id="@+id/stepRow6"
                    android:layout_width="match_parent" android:layout_height="58dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:background="@drawable/bg_step_locked"
                    android:paddingStart="10dp" android:paddingEnd="12dp"
                    android:layout_marginStart="30dp" android:layout_marginEnd="6dp"
                    android:layout_marginBottom="4dp">
                    <FrameLayout android:layout_width="28dp" android:layout_height="28dp"
                        android:background="@drawable/bg_step_number_circle" android:layout_marginEnd="10dp">
                        <TextView android:layout_width="match_parent" android:layout_height="match_parent"
                            android:gravity="center" android:fontFamily="sans-serif-black"
                            android:textColor="#FFFFFF" android:textSize="13sp" android:text="6"/>
                    </FrameLayout>
                    <TextView android:id="@+id/tvClue6"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:fontFamily="sans-serif-black"
                        android:textColor="#80000000" android:textSize="13sp" android:text="—  ZAKLJUČAN  —"/>
                    <TextView android:id="@+id/tvPoints6"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black" android:textColor="#80000000"
                        android:textSize="12sp" android:text="10★"/>
                </LinearLayout>

                <!-- ══ KORAK 7 ══ -->
                <LinearLayout android:id="@+id/stepRow7"
                    android:layout_width="match_parent" android:layout_height="58dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:background="@drawable/bg_step_locked"
                    android:paddingStart="10dp" android:paddingEnd="12dp"
                    android:layout_marginStart="36dp" android:layout_marginEnd="0dp"
                    android:layout_marginBottom="4dp">
                    <FrameLayout android:layout_width="28dp" android:layout_height="28dp"
                        android:background="@drawable/bg_step_number_circle" android:layout_marginEnd="10dp">
                        <TextView android:layout_width="match_parent" android:layout_height="match_parent"
                            android:gravity="center" android:fontFamily="sans-serif-black"
                            android:textColor="#FFFFFF" android:textSize="13sp" android:text="7"/>
                    </FrameLayout>
                    <TextView android:id="@+id/tvClue7"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:fontFamily="sans-serif-black"
                        android:textColor="#80000000" android:textSize="13sp" android:text="—  ZAKLJUČAN  —"/>
                    <TextView android:id="@+id/tvPoints7"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black" android:textColor="#80000000"
                        android:textSize="12sp" android:text="8★"/>
                </LinearLayout>

            </LinearLayout>
        </FrameLayout>
    </ScrollView>

    <!-- ── FIKSIRANI DNO: unos + dugme (bez tamne status trake) ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="16dp">

        <!-- Polje za unos odgovora — krem kartica sa zaobljenim uglovima -->
        <EditText
            android:id="@+id/etAnswer"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:background="@drawable/bg_expression_display"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingTop="0dp"
            android:paddingBottom="5dp"
            android:gravity="center_vertical"
            android:fontFamily="sans-serif-black"
            android:textSize="17sp"
            android:textColor="@color/ink"
            android:hint="@string/hint_answer"
            android:inputType="textCapCharacters"
            android:singleLine="true"
            android:layout_marginBottom="10dp"/>

        <!-- Pošalji odgovor — zeleno dugme -->
        <Button
            android:id="@+id/btnConfirm"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            style="@style/CartoonButton"
            android:textSize="18sp"
            android:text="POŠALJI ODGOVOR"
            android:background="@drawable/btn_cartoon_green"/>

        <!-- OBRIŠI i PREDAJ — skriveni, ID-ovi ostaju za Java -->
        <Button android:id="@+id/btnDelete"
            android:layout_width="0dp" android:layout_height="0dp"
            android:visibility="gone"/>
        <Button android:id="@+id/btnSurrender"
            android:layout_width="0dp" android:layout_height="0dp"
            android:visibility="gone"/>
    </LinearLayout>

</LinearLayout>
