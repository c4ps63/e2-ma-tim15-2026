<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_sky_gradient">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_hud"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="48dp"
        android:paddingBottom="14dp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:minHeight="0dp"
            android:gravity="center"
            android:text="←"
            android:fontFamily="monospace"
            android:textSize="20sp"
            android:textColor="@color/ink"
            android:background="@drawable/card_paper"
            android:paddingTop="4dp"
            android:paddingBottom="8dp"
            android:paddingLeft="0dp"
            android:paddingRight="0dp"
            android:layout_marginEnd="12dp"/>

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_trophy"
            app:tint="#FFD23F"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-black"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:letterSpacing="0.04"
            android:text="@string/label_tournament"/>

        <TextView
            android:id="@+id/tvPlayerCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/chip_cartoon"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="6dp"
            android:fontFamily="sans-serif-black"
            android:textColor="@color/ink"
            android:textSize="14sp"
            android:text="0/4"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#60FFFFFF"/>

    <!-- Status text -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:gravity="center"
        android:fontFamily="sans-serif"
        android:textColor="#CCFFFFFF"
        android:textSize="13sp"
        android:text="@string/tournament_searching"/>

    <!-- Bracket -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="12dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <!-- ── Polufinale 1 card ────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_paper"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="10dp"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:textColor="@color/ink"
                    android:alpha="0.5"
                    android:textSize="10sp"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="10dp"
                    android:text="@string/tournament_semifinal1"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- Slot 1 -->
                    <LinearLayout
                        android:id="@+id/cardSlot1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp">

                        <TextView
                            android:id="@+id/tvInit1"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:gravity="center"
                            android:fontFamily="sans-serif-black"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:text="?"/>

                        <TextView
                            android:id="@+id/tvUser1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:gravity="center"
                            android:fontFamily="sans-serif-black"
                            android:textColor="@color/ink"
                            android:textSize="12sp"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:text="@string/tournament_slot_waiting"/>

                        <TextView
                            android:id="@+id/tvLg1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:fontFamily="sans-serif"
                            android:textColor="@color/ink"
                            android:alpha="0.5"
                            android:textSize="10sp"
                            android:text="—"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:textColor="@color/ink"
                        android:alpha="0.4"
                        android:textSize="13sp"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp"
                        android:text="VS"/>

                    <!-- Slot 2 -->
                    <LinearLayout
                        android:id="@+id/cardSlot2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp">

                        <TextView
                            android:id="@+id/tvInit2"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:gravity="center"
                            android:fontFamily="sans-serif-black"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:text="?"/>

                        <TextView
                            android:id="@+id/tvUser2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:gravity="center"
                            android:fontFamily="sans-serif-black"
                            android:textColor="@color/ink"
                            android:textSize="12sp"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:text="@string/tournament_slot_waiting"/>

                        <TextView
                            android:id="@+id/tvLg2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:fontFamily="sans-serif"
                            android:textColor="@color/ink"
                            android:alpha="0.5"
                            android:textSize="10sp"
                            android:text="—"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ── Bracket connector ──────────────────────────────────── -->
            <View
                android:layout_width="2dp"
                android:layout_height="18dp"
                android:background="#80FFFFFF"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/btn_cartoon_yellow"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="6dp"
                android:paddingBottom="10dp"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/ink"
                android:textSize="13sp"
                android:letterSpacing="0.06"
                android:text="@string/tournament_final"/>

            <View
                android:layout_width="2dp"
                android:layout_height="18dp"
                android:background="#80FFFFFF"/>

            <!-- ── Polufinale 2 card ────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_paper"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="10dp"
                android:paddingBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- Slot 3 -->
                    <LinearLayout
                        android:id="@+id/cardSlot3"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp">

                        <TextView
                            android:id="@+id/tvInit3"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:gravity="center"
                            android:fontFamily="sans-serif-black"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:text="?"/>

                        <TextView
                            android:id="@+id/tvUser3"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:gravity="center"
                            android:fontFamily="sans-serif-black"
                            android:textColor="@color/ink"
                            android:textSize="12sp"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:text="@string/tournament_slot_waiting"/>

                        <TextView
                            android:id="@+id/tvLg3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:fontFamily="sans-serif"
                            android:textColor="@color/ink"
                            android:alpha="0.5"
                            android:textSize="10sp"
                            android:text="—"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:textColor="@color/ink"
                        android:alpha="0.4"
                        android:textSize="13sp"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp"
                        android:text="VS"/>

                    <!-- Slot 4 -->
                    <LinearLayout
                        android:id="@+id/cardSlot4"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp">

                        <TextView
                            android:id="@+id/tvInit4"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:gravity="center"
                            android:fontFamily="sans-serif-black"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:text="?"/>

                        <TextView
                            android:id="@+id/tvUser4"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:gravity="center"
                            android:fontFamily="sans-serif-black"
                            android:textColor="@color/ink"
                            android:textSize="12sp"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:text="@string/tournament_slot_waiting"/>

                        <TextView
                            android:id="@+id/tvLg4"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:fontFamily="sans-serif"
                            android:textColor="@color/ink"
                            android:alpha="0.5"
                            android:textSize="10sp"
                            android:text="—"/>
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="sans-serif-black"
                    android:textColor="@color/ink"
                    android:alpha="0.5"
                    android:textSize="10sp"
                    android:letterSpacing="0.08"
                    android:text="@string/tournament_semifinal2"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
