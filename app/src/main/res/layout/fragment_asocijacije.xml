<?xml version="1.0" encoding="utf-8"?>
<!-- ASOCIJACIJE · AFRIKA · cartoon dizajn — 2+2 layout -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_game_asocijacije">

    <include layout="@layout/include_hud"/>

    <!-- Baner: naziv igre + PREDAJ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/af_1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp" android:paddingEnd="10dp"
        android:paddingTop="8dp" android:paddingBottom="8dp">

        <TextView
            android:id="@+id/tvRound"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-black"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:letterSpacing="0.04"
            android:text="🦁 AFRIKA · ASOCIJACIJE"/>

        <Button
            android:id="@+id/btnSurrender"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            style="@style/CartoonButton"
            android:paddingTop="4dp"
            android:paddingBottom="8dp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textSize="12sp"
            android:text="@string/btn_surrender"
            android:background="@drawable/btn_cartoon_red"/>
    </LinearLayout>

    <!-- Sadržaj igre -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="8dp">

        <!-- GORNJA POLOVINA: Kolone A i B — ćelije 1-4, rešenje na dnu (blizu centra) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <!-- Kolona A -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="4dp">

                <Button android:id="@+id/tvCellA1"
                    android:layout_width="match_parent" android:layout_height="0dp"
                    android:layout_weight="1" android:layout_marginBottom="3dp"
                    style="@style/CartoonButton"
                    android:paddingTop="4dp" android:paddingBottom="8dp"
                    android:paddingLeft="4dp" android:paddingRight="4dp"
                    android:gravity="center" android:minHeight="0dp"
                    android:text="MLEKO" android:textSize="12sp"
                    android:textColor="@color/ink"
                    android:background="@drawable/btn_cartoon_yellow"/>
                <Button android:id="@+id/tvCellA2"
                    android:layout_width="match_parent" android:layout_height="0dp"
                    android:layout_weight="1" android:layout_marginBottom="3dp"
                    style="@style/CartoonButton"
                    android:paddingTop="4dp" android:paddingBottom="8dp"
                    android:paddingLeft="4dp" android:paddingRight="4dp"
                    android:gravity="center" android:minHeight="0dp"
                    android:text="?" android:textSize="16sp"
                    android:textColor="@color/ink"
                    android:alpha="0.55"
                    android:background="@drawable/btn_cartoon_yellow"/>
                <Button android:id="@+id/tvCellA3"
                    android:layout_width="match_parent" android:layout_height="0dp"
                    android:layout_weight="1" android:layout_marginBottom="3dp"
                    style="@style/CartoonButton"
                    android:paddingTop="4dp" android:paddingBottom="8dp"
                    android:paddingLeft="4dp" android:paddingRight="4dp"
                    android:gravity="center" android:minHeight="0dp"
                    android:text="?" android:textSize="16sp"
                    android:textColor="@color/ink"
                    android:alpha="0.55"
                    android:background="@drawable/btn_cartoon_yellow"/>
                <Button android:id="@+id/tvCellA4"
                    android:layout_width="match_parent" android:layout_height="0dp"
                    android:layout_weight="1" android:layout_marginBottom="4dp"
                    style="@style/CartoonButton"
                    android:paddingTop="4dp" android:paddingBottom="8dp"
                    android:paddingLeft="4dp" android:paddingRight="4dp"
                    android:gravity="center" android:minHeight="0dp"
                    android:text="?" android:textSize="16sp"
                    android:textColor="@color/ink"
                    android:alpha="0.55"
                    android:background="@drawable/btn_cartoon_yellow"/>

                <!-- Rešenje A — na dnu gornje polovine, najbliže centru -->
                <Button android:id="@+id/tvColHeaderA"
                    android:layout_width="match_parent" android:layout_height="42dp"
                    style="@style/CartoonButton"
                    android:paddingTop="4dp" android:paddingBottom="8dp"
                    android:paddingLeft="4dp" android:paddingRight="4dp"
                    android:gravity="center" android:minHeight="0dp"
                    android:text="A" android:textSize="13sp"
                    android:background="@drawable/btn_cartoon_red"/>
            </LinearLayout>

            <!-- Kolona B -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="4dp">

                <Button android:id="@+id/tvCellB1"
                    android:layout_width="match_parent" android:layout_height="0dp"
                    android:layout_weight="1" android:layout_marginBottom="3dp"
                    style="@style/CartoonButton"
                    android:paddingTop="4dp" android:paddingBottom="8dp"
                    android:paddingLeft="4dp" android:paddingRight="4dp"
                    android:gravity="center" android:minHeight="0dp"
                    android:text="PLAVO" android:textSize="12sp"
                    android:textColor="@color/ink"
                    android:background="@drawable/btn_cartoon_yellow"/>
                <Button android:id="@+id/tvCellB2"
                    android:layout_width="match_parent" android:layout_height="0dp"
                    android:layout_weight="1" android:layout_marginBottom="3dp"
                    style="@style/CartoonButton"
                    android:paddingTop="4dp" android:paddingBottom="8dp"
                    android:paddingLeft="4dp" android:paddingRight="4dp"
                    android:gravity="center" android:minHeight="0dp"
                    android:text="OBLAK" android:textSize="12sp"
                    android:textColor="@color/ink"
                    android:background="@drawable/btn_cartoon_yellow"/>
                <Button android:id="@+id/tvCellB3"
                    android:layout_width="match_parent" android:layout_height="0dp"
                    android:layout_weight="1" android:layout_marginBottom="3dp"
                    style="@style/CartoonButton"
                    android:paddingTop="4dp" android:paddingBottom="8dp"
                    android:paddingLeft="4dp" android:paddingRight="4dp"
                    android:gravity="center" android:minHeight="0dp"
                    android:text="?" android:textSize="16sp"
                    android:textColor="@color/ink"
                    android:alpha="0.55"
                    android:background="@drawable/btn_cartoon_yellow"/>
                <Button android:id="@+id/tvCellB4"
                    android:layout_width="match_parent" android:layout_height="0dp"
                    android:layout_weight="1" android:layout_marginBottom="4dp"
                    style="@style/CartoonButton"
                    android:paddingTop="4dp" android:paddingBottom="8dp"
                    android:paddingLeft="4dp" android:paddingRight="4dp"
                    android:gravity="center" android:minHeight="0dp"
                    android:text="?" android:textSize="16sp"
                    android:textColor="@color/ink"
                    android:alpha="0.55"
                    android:background="@drawable/btn_cartoon_yellow"/>

                <!-- Rešenje B — na dnu gornje polovine, najbliže centru -->
                <Button android:id="@+id/tvColHeaderB"
                    android:layout_width="match_parent" android:layout_height="42dp"
                    style="@style/CartoonButton"
                    android:paddingTop="4dp" android:paddingBottom="8dp"
                    android:paddingLeft="4dp" android:paddingRight="4dp"
                    android:gravity="center" android:minHeight="0dp"
                    android:text="B" android:textSize="13sp"
                    android:background="@drawable/btn_cartoon_red"/>
            </LinearLayout>
        </LinearLayout>

        <!-- CENTAR: Traka konačnog rešenja -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="6dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:background="@drawable/card_paper"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="8dp"
                android:paddingBottom="6dp">
                <TextView
                    android:id="@+id/tvFinalAnswer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:textColor="@color/ink"
                    android:textSize="18sp"
                    android:gravity="center"
                    android:text="@string/label_final_answer"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnSubmit"
                android:layout_width="wrap_content"
                android:layout_height="52dp"
                android:layout_marginStart="8dp"
                style="@style/CartoonButton"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="4dp"
                android:paddingBottom="10dp"
                android:textSize="15sp"
                android:text="@string/btn_submit"
                android:textColor="@color/ink"
                android:background="@drawable/btn_cartoon_yellow"/>
        </LinearLayout>

        <!-- DONJA POLOVINA: Kolone C i D — rešenje na vrhu (blizu centra), ćelije ispod -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <!-- Kolona C -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="4dp">

                <!-- Rešenje C — na vrhu donje polovine, najbliže centru -->
                <Button android:id="@+id/tvColHeaderC"
                    android:layout_width="match_parent" android:layout_height="42dp"
                    style="@style/CartoonButton"
                    android:paddingTop="4dp" android:paddingBottom="8dp"
                    android:paddingLeft="4dp" android:paddingRight="4dp"
                    android:gravity="center" android:minHeight="0dp"
                    android:text="C" android:textSize="13sp"
                    android:background="@drawable/btn_cartoon_red"/>

                <Button android:id="@+id/tvCellC1"
                    android:layout_width="match_parent" android:layout_height="0dp"
                    android:layout_weight="1" android:layout_marginTop="4dp"
                    android:layout_marginBottom="3dp"
                    style="@style/CartoonButton"
                    android:paddingTop="4dp" android:paddingBottom="8dp"
                    android:paddingLeft="4dp" android:paddingRight="4dp"
                    android:gravity="center" android:minHeight="0dp"
                    android:text="TRAVA" android:textSize="12sp"
                    android:textColor="@color/ink"
                    android:background="@drawable/btn_cartoon_yellow"/>
                <Button android:id="@+id/tvCellC2"
                    android:layout_width="match_parent" android:layout_height="0dp"
                    android:layout_weight="1" android:layout_marginBottom="3dp"
                    style="@style/CartoonButton"
                    android:paddingTop="4dp" android:paddingBottom="8dp"
                    android:paddingLeft="4dp" android:paddingRight="4dp"
                    android:gravity="center" android:minHeight="0dp"
                    android:text="ŽABA" android:textSize="12sp"
                    android:textColor="@color/ink"
                    android:background="@drawable/btn_cartoon_yellow"/>
                <Button android:id="@+id/tvCellC3"
                    android:layout_width="match_parent" android:layout_height="0dp"
                    android:layout_weight="1" android:layout_marginBottom="3dp"
                    style="@style/CartoonButton"
                    android:paddingTop="4dp" android:paddingBottom="8dp"
                    android:paddingLeft="4dp" android:paddingRight="4dp"
                    android:gravity="center" android:minHeight="0dp"
                    android:text="?" android:textSize="16sp"
                    android:textColor="@color/ink"
                    android:alpha="0.55"
                    android:background="@drawable/btn_cartoon_yellow"/>
                <Button android:id="@+id/tvCellC4"
                    android:layout_width="match_parent" android:layout_height="0dp"
                    android:layout_weight="1"
                    style="@style/CartoonButton"
                    android:paddingTop="4dp" android:paddingBottom="8dp"
                    android:paddingLeft="4dp" android:paddingRight="4dp"
                    android:gravity="center" android:minHeight="0dp"
                    android:text="?" android:textSize="16sp"
                    android:textColor="@color/ink"
                    android:alpha="0.55"
                    android:background="@drawable/btn_cartoon_yellow"/>
            </LinearLayout>

            <!-- Kolona D -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="4dp">

                <!-- Rešenje D — na vrhu donje polovine, najbliže centru -->
                <Button android:id="@+id/tvColHeaderD"
                    android:layout_width="match_parent" android:layout_height="42dp"
                    style="@style/CartoonButton"
                    android:paddingTop="4dp" android:paddingBottom="8dp"
                    android:paddingLeft="4dp" android:paddingRight="4dp"
                    android:gravity="center" android:minHeight="0dp"
                    android:text="D" android:textSize="13sp"
                    android:background="@drawable/btn_cartoon_red"/>

                <Button android:id="@+id/tvCellD1"
                    android:layout_width="match_parent" android:layout_height="0dp"
                    android:layout_weight="1" android:layout_marginTop="4dp"
                    android:layout_marginBottom="3dp"
                    style="@style/CartoonButton"
                    android:paddingTop="4dp" android:paddingBottom="8dp"
                    android:paddingLeft="4dp" android:paddingRight="4dp"
                    android:gravity="center" android:minHeight="0dp"
                    android:text="?" android:textSize="16sp"
                    android:textColor="@color/ink"
                    android:alpha="0.55"
                    android:background="@drawable/btn_cartoon_yellow"/>
                <Button android:id="@+id/tvCellD2"
                    android:layout_width="match_parent" android:layout_height="0dp"
                    android:layout_weight="1" android:layout_marginBottom="3dp"
                    style="@style/CartoonButton"
                    android:paddingTop="4dp" android:paddingBottom="8dp"
                    android:paddingLeft="4dp" android:paddingRight="4dp"
                    android:gravity="center" android:minHeight="0dp"
                    android:text="KRV" android:textSize="12sp"
                    android:textColor="@color/ink"
                    android:background="@drawable/btn_cartoon_yellow"/>
                <Button android:id="@+id/tvCellD3"
                    android:layout_width="match_parent" android:layout_height="0dp"
                    android:layout_weight="1" android:layout_marginBottom="3dp"
                    style="@style/CartoonButton"
                    android:paddingTop="4dp" android:paddingBottom="8dp"
                    android:paddingLeft="4dp" android:paddingRight="4dp"
                    android:gravity="center" android:minHeight="0dp"
                    android:text="?" android:textSize="16sp"
                    android:textColor="@color/ink"
                    android:alpha="0.55"
                    android:background="@drawable/btn_cartoon_yellow"/>
                <Button android:id="@+id/tvCellD4"
                    android:layout_width="match_parent" android:layout_height="0dp"
                    android:layout_weight="1"
                    style="@style/CartoonButton"
                    android:paddingTop="4dp" android:paddingBottom="8dp"
                    android:paddingLeft="4dp" android:paddingRight="4dp"
                    android:gravity="center" android:minHeight="0dp"
                    android:text="VATRA" android:textSize="12sp"
                    android:textColor="@color/ink"
                    android:background="@drawable/btn_cartoon_yellow"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</LinearLayout>
