<?xml version="1.0" encoding="utf-8"?>
<!-- HOME: HUD chips + avatar · centralni "ZAPOČNI PARTIJU" · IGRAJ · 4 prečice. -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/home_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_home_sky">

    <!-- ===== BACKGROUND DECOR (raspoređeni glyph-ovi, nizak alpha) ===== -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:importantForAccessibility="no"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView android:layout_width="50dp" android:layout_height="50dp"
            android:layout_marginTop="150dp" android:layout_marginStart="26dp"
            android:rotation="-16" android:alpha="0.10"
            android:src="@drawable/ic_glyph_star" app:tint="#FFFFFF"/>
        <ImageView android:layout_width="34dp" android:layout_height="34dp"
            android:layout_gravity="end" android:layout_marginTop="128dp" android:layout_marginEnd="46dp"
            android:rotation="12" android:alpha="0.10"
            android:src="@drawable/ic_glyph_diamond" app:tint="#FFFFFF"/>
        <ImageView android:layout_width="42dp" android:layout_height="42dp"
            android:layout_gravity="end" android:layout_marginTop="238dp" android:layout_marginEnd="62dp"
            android:alpha="0.09"
            android:src="@drawable/ic_glyph_circle" app:tint="#FFFFFF"/>
        <ImageView android:layout_width="54dp" android:layout_height="54dp"
            android:layout_marginTop="520dp" android:layout_marginStart="30dp"
            android:rotation="8" android:alpha="0.09"
            android:src="@drawable/ic_glyph_triangle" app:tint="#FFFFFF"/>
        <ImageView android:layout_width="40dp" android:layout_height="40dp"
            android:layout_gravity="bottom|end" android:layout_marginBottom="150dp" android:layout_marginEnd="34dp"
            android:rotation="-10" android:alpha="0.10"
            android:src="@drawable/ic_glyph_heart" app:tint="#FFFFFF"/>
        <ImageView android:layout_width="34dp" android:layout_height="34dp"
            android:layout_gravity="bottom" android:layout_marginBottom="118dp" android:layout_marginStart="28dp"
            android:rotation="18" android:alpha="0.09"
            android:src="@drawable/ic_glyph_square" app:tint="#FFFFFF"/>
        <ImageView android:layout_width="26dp" android:layout_height="26dp"
            android:layout_gravity="end" android:layout_marginTop="435dp" android:layout_marginEnd="30dp"
            android:rotation="-8" android:alpha="0.10"
            android:src="@drawable/ic_glyph_star" app:tint="#FFFFFF"/>
    </FrameLayout>

    <!-- ===== TOP HUD ===== -->
    <LinearLayout
        android:id="@+id/hud"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="@dimen/status_bar_safe"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- token chip -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/chip_cartoon"
            android:paddingStart="11dp" android:paddingEnd="11dp"
            android:paddingTop="6dp" android:paddingBottom="9dp">
            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                android:src="@drawable/ic_glyph_diamond" app:tint="#39B6FF"/>
            <TextView
                android:id="@+id/tvTokens"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/ink" android:textSize="16sp"
                android:text="5"/>
        </LinearLayout>

        <Space android:layout_width="9dp" android:layout_height="1dp"/>

        <!-- star chip -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/chip_cartoon"
            android:paddingStart="11dp" android:paddingEnd="11dp"
            android:paddingTop="6dp" android:paddingBottom="9dp">
            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                android:src="@drawable/ic_glyph_star" app:tint="#FFD23F"/>
            <TextView
                android:id="@+id/tvStars"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/ink" android:textSize="16sp"
                android:text="0"/>
        </LinearLayout>

        <Space android:layout_width="9dp" android:layout_height="1dp"/>

        <!-- league chip -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/chip_cartoon"
            android:paddingStart="6dp" android:paddingEnd="11dp"
            android:paddingTop="5dp" android:paddingBottom="8dp">
            <FrameLayout
                android:layout_width="26dp" android:layout_height="26dp">
                <ImageView android:layout_width="26dp" android:layout_height="26dp"
                    android:src="@drawable/ic_shield"/>
            </FrameLayout>
            <TextView
                android:id="@+id/tvLeague"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="7dp"
                android:maxLines="1" android:ellipsize="end"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/ink" android:textSize="15sp"
                android:text="1. LIGA"/>
        </LinearLayout>

        <Space android:layout_width="10dp" android:layout_height="1dp"/>

        <!-- avatar -> profil -->
        <FrameLayout
            android:id="@+id/btnProfile"
            android:layout_width="48dp" android:layout_height="48dp"
            android:background="@drawable/avatar_circle"
            android:clickable="true" android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless">
            <TextView
                android:id="@+id/tvAvatarLetter"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:gravity="center"
                android:fontFamily="sans-serif-black"
                android:textColor="#FFFFFF" android:textSize="18sp"
                android:text="?"/>
        </FrameLayout>

        <Space android:layout_width="8dp" android:layout_height="1dp"/>

        <!-- zvonce → NotificationsActivity -->
        <FrameLayout
            android:id="@+id/btnNotifications"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_bell"/>

            <TextView
                android:id="@+id/tvNotifBadge"
                android:layout_width="17dp"
                android:layout_height="17dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="1dp"
                android:background="@drawable/btn_cartoon_red"
                android:fontFamily="sans-serif-black"
                android:textSize="8sp"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:paddingBottom="2dp"
                android:visibility="gone"/>
        </FrameLayout>
    </LinearLayout>

    <!-- ===== CENTER: glavno dugme + IGRAJ ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="22dp" android:paddingEnd="22dp"
        app:layout_constraintTop_toBottomOf="@id/hud"
        app:layout_constraintBottom_toTopOf="@id/bottom_row"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- ZAPOČNI PARTIJU -->
        <LinearLayout
            android:id="@+id/btnPlayOnline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/btn_main_green"
            android:clickable="true" android:focusable="true"
            android:paddingTop="22dp" android:paddingBottom="22dp"
            android:paddingStart="20dp" android:paddingEnd="20dp">
            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:gravity="center"
                android:fontFamily="sans-serif-black"
                android:textColor="#FFFFFF" android:textSize="30sp"
                android:lineSpacingMultiplier="0.96"
                android:shadowColor="#5206112A" android:shadowDx="0" android:shadowDy="3" android:shadowRadius="0.1"
                android:text="@string/cta_start"/>
            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/pill_translucent"
                android:paddingStart="12dp" android:paddingEnd="12dp"
                android:paddingTop="5dp" android:paddingBottom="5dp"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold"
                android:textColor="#06351F" android:textSize="13sp"
                android:text="@string/cta_start_sub"/>
        </LinearLayout>

        <!-- IGRAJ -->
        <LinearLayout
            android:id="@+id/btnPlay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/btn_play_yellow"
            android:clickable="true" android:focusable="true"
            android:paddingStart="22dp" android:paddingEnd="22dp"
            android:paddingTop="13dp" android:paddingBottom="16dp">
            <ImageView android:layout_width="20dp" android:layout_height="20dp"
                android:src="@drawable/ic_grid" app:tint="@color/ink"/>
            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginStart="10dp" android:layout_marginEnd="10dp"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/ink" android:textSize="21sp"
                android:text="@string/cta_play"/>
            <ImageView android:layout_width="20dp" android:layout_height="20dp"
                android:src="@drawable/ic_chevron_down" app:tint="@color/ink"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ===== BOTTOM ROW: 4 prečice ===== -->
    <LinearLayout
        android:id="@+id/bottom_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="18dp" android:paddingEnd="18dp"
        android:paddingBottom="26dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Prijatelji -->
        <LinearLayout android:id="@+id/navPrijatelji"
            android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
            android:orientation="vertical" android:gravity="center"
            android:clickable="true" android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">
            <LinearLayout android:layout_width="60dp" android:layout_height="64dp"
                android:gravity="center" android:background="@drawable/tile_green">
                <ImageView android:layout_width="28dp" android:layout_height="28dp"
                    android:src="@drawable/ic_friends" app:tint="#FFFFFF"/>
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="sans-serif-medium" android:textStyle="bold"
                android:textColor="#FFFFFF" android:textSize="12sp"
                android:shadowColor="#6606112A" android:shadowDy="1" android:shadowRadius="2"
                android:text="@string/nav_friends"/>
        </LinearLayout>

        <!-- Rang liste -->
        <LinearLayout android:id="@+id/navRang"
            android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
            android:orientation="vertical" android:gravity="center"
            android:clickable="true" android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">
            <LinearLayout android:layout_width="60dp" android:layout_height="64dp"
                android:gravity="center" android:background="@drawable/tile_yellow">
                <ImageView android:layout_width="28dp" android:layout_height="28dp"
                    android:src="@drawable/ic_trophy" app:tint="@color/ink"/>
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="sans-serif-medium" android:textStyle="bold"
                android:textColor="#FFFFFF" android:textSize="12sp"
                android:shadowColor="#6606112A" android:shadowDy="1" android:shadowRadius="2"
                android:text="@string/nav_ranks"/>
        </LinearLayout>

        <!-- Regioni -->
        <LinearLayout android:id="@+id/navRegioni"
            android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
            android:orientation="vertical" android:gravity="center"
            android:clickable="true" android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">
            <LinearLayout android:layout_width="60dp" android:layout_height="64dp"
                android:gravity="center" android:background="@drawable/tile_coral">
                <ImageView android:layout_width="27dp" android:layout_height="27dp"
                    android:src="@drawable/ic_pin" app:tint="#FFFFFF"/>
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="sans-serif-medium" android:textStyle="bold"
                android:textColor="#FFFFFF" android:textSize="12sp"
                android:shadowColor="#6606112A" android:shadowDy="1" android:shadowRadius="2"
                android:text="@string/nav_regions"/>
        </LinearLayout>

        <!-- Čet -->
        <LinearLayout android:id="@+id/navCet"
            android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
            android:orientation="vertical" android:gravity="center"
            android:clickable="true" android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">
            <LinearLayout android:layout_width="60dp" android:layout_height="64dp"
                android:gravity="center" android:background="@drawable/tile_blue">
                <ImageView android:layout_width="27dp" android:layout_height="27dp"
                    android:src="@drawable/ic_chat" app:tint="#FFFFFF"/>
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="sans-serif-medium" android:textStyle="bold"
                android:textColor="#FFFFFF" android:textSize="12sp"
                android:shadowColor="#6606112A" android:shadowDy="1" android:shadowRadius="2"
                android:text="@string/nav_chat"/>
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
