<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Force retro light style even in dark mode -->
    <style name="Base.Theme.SlagalicaVPL" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:statusBarColor">@color/retro_ink</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
        <item name="android:windowBackground">@color/retro_bg</item>
        <item name="colorPrimary">@color/retro_acc</item>
        <item name="colorOnPrimary">@color/retro_bg</item>
        <item name="colorSurface">@color/retro_bg</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="28">shortEdges</item>
    </style>
</resources>