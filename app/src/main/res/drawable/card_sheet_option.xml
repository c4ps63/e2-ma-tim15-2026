<?xml version="1.0" encoding="utf-8"?>
<!-- Opcija u play sheet-u (paper kartica + cartoon senka). -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:top="5dp">
        <shape android:shape="rectangle"><solid android:color="@color/ink_dark"/><corners android:radius="16dp"/></shape>
    </item>
    <item android:bottom="5dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/paper"/>
            <stroke android:width="3dp" android:color="@color/ink_dark"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>
</layer-list>
