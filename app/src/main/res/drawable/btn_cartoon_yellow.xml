<?xml version="1.0" encoding="utf-8"?>
<!-- Cartoon "plastic" button — yellow/gold variant -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- drop shadow / 3D bottom -->
    <item android:top="4dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/ink"/>
            <corners android:radius="@dimen/btn_radius"/>
        </shape>
    </item>
    <!-- face -->
    <item android:bottom="4dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#FFD84A"
                android:endColor="#FFA820"/>
            <stroke android:width="@dimen/stroke_thick" android:color="@color/ink"/>
            <corners android:radius="@dimen/btn_radius"/>
        </shape>
    </item>
</layer-list>
