<?xml version="1.0" encoding="utf-8"?>
<!-- Cartoon button — salmon/losos varijanta za neodabrane stavke u Spojnicama -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:top="4dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/ink"/>
            <corners android:radius="@dimen/btn_radius"/>
        </shape>
    </item>
    <item android:bottom="4dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#FFCFC0"
                android:endColor="#FFB8A4"/>
            <stroke android:width="@dimen/stroke_thick" android:color="@color/ink"/>
            <corners android:radius="@dimen/btn_radius"/>
        </shape>
    </item>
</layer-list>
