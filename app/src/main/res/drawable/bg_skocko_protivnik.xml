<?xml version="1.0" encoding="utf-8"?>
<!-- PROTIVNIK red: rgba(10,61,42,0.55) → #8C0A3D2A, 3dp shadow, 3dp stroke, radius 12dp -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- shadow -->
    <item android:top="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#0A3D2A"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>
    <!-- face -->
    <item android:bottom="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#8C0A3D2A"/>
            <stroke android:width="3dp" android:color="#0A3D2A"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>
</layer-list>
