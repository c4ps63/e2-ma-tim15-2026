<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Osnova planete (okean — tamnoplava sa konturom) -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="55%p"
                android:centerX="0.38"
                android:centerY="0.32"
                android:startColor="#4FC3F7"
                android:endColor="#01579B"/>
            <stroke android:width="4dp" android:color="#0A2547"/>
        </shape>
    </item>

    <!-- Kontinenti — gornji levi zeleni flek -->
    <item
        android:left="22dp"
        android:top="30dp"
        android:right="110dp"
        android:bottom="110dp">
        <shape android:shape="oval">
            <solid android:color="#388E3C"/>
        </shape>
    </item>

    <!-- Kontinenti — desni zeleni flek -->
    <item
        android:left="110dp"
        android:top="50dp"
        android:right="30dp"
        android:bottom="80dp">
        <shape android:shape="oval">
            <solid android:color="#2E7D32"/>
        </shape>
    </item>

    <!-- Kontinenti — donji zeleni flek -->
    <item
        android:left="50dp"
        android:top="120dp"
        android:right="80dp"
        android:bottom="20dp">
        <shape android:shape="oval">
            <solid android:color="#43A047"/>
        </shape>
    </item>

    <!-- Sjaj (highlight) -->
    <item
        android:left="30dp"
        android:top="20dp"
        android:right="130dp"
        android:bottom="130dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="50%p"
                android:centerX="0.5"
                android:centerY="0.5"
                android:startColor="#80FFFFFF"
                android:endColor="#00FFFFFF"/>
        </shape>
    </item>

</layer-list>
