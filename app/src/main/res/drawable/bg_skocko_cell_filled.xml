<?xml version="1.0" encoding="utf-8"?>
<!-- Popunjena Ä‡elija SkoÄŤko: gradient bijelaâ†’svetlozelena, 3dp shadow, 3dp stroke, radius 10dp -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- shadow (bottom 3dp) -->
    <item android:top="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#0A3D2A"/>
            <corners android:radius="10dp"/>
        </shape>
    </item>
    <!-- face -->
    <item android:bottom="3dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#FFFFFF"
                android:endColor="#CFE9D6"/>
            <stroke android:width="3dp" android:color="#0A3D2A"/>
            <corners android:radius="10dp"/>
        </shape>
    </item>
</layer-list>
