<?xml version="1.0" encoding="utf-8"?>
<!-- Moj Broj operator tile: yellow/gold gradient, dark brown border + shadow -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:top="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#3a1410"/>
            <corners android:radius="10dp"/>
        </shape>
    </item>
    <item android:bottom="3dp">
        <shape android:shape="rectangle">
            <gradient android:angle="270" android:startColor="#FFD23F" android:endColor="#e89a16"/>
            <stroke android:width="3dp" android:color="#3a1410"/>
            <corners android:radius="10dp"/>
        </shape>
    </item>
</layer-list>
