<?xml version="1.0" encoding="utf-8"?>
<!-- REĹ ENJE red: gradient Ĺľutaâ†’narandĹľasta, 4dp shadow, 3dp stroke, radius 12dp -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- shadow -->
    <item android:top="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#0A3D2A"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>
    <!-- face -->
    <item android:bottom="4dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#FFD23F"
                android:endColor="#E89A16"/>
            <stroke android:width="3dp" android:color="#0A3D2A"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>
</layer-list>
