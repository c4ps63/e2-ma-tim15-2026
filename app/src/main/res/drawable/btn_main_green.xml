<?xml version="1.0" encoding="utf-8"?>
<!-- Glavno dugme ZAPOČNI PARTIJU (zelena, velika senka). -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:top="7dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/ink"/>
            <corners android:radius="24dp"/>
        </shape>
    </item>
    <item android:bottom="7dp">
        <shape android:shape="rectangle">
            <gradient android:angle="270" android:startColor="#0FA055" android:centerColor="#22BD78" android:endColor="#5BE29A"/>
            <stroke android:width="3.5dp" android:color="@color/ink"/>
            <corners android:radius="24dp"/>
        </shape>
    </item>
</layer-list>
